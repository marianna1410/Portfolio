---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Works from '../components/Works.astro';
---

<BaseLayout title="Marianna Delihioz — Portfolio">
  <Hero />
  <Works />

  <section id="experience" style="min-height: 80vh; padding-block: var(--space-stack-5xl);">
    <div class="container">
      <h2 class="text-h2">Experience placeholder</h2>
    </div>
  </section>

  <section id="about" style="min-height: 80vh; padding-block: var(--space-stack-5xl); background: var(--color-bg-grey-muted);">
    <div class="container">
      <h2 class="text-h2">Behind the Screen placeholder</h2>
    </div>
  </section>
</BaseLayout>
