---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** 'home' = nav with Works/Experience/About. 'case' = Go Home link. */
  headerVariant?: 'home' | 'case';
  /** 'default' = light-grey bg / white card. 'case' = inverted (white bg / light-grey card). */
  footerVariant?: 'default' | 'case';
}

const {
  title,
  description = 'Marianna Delihioz — Designer who creates digital experiences for humans.',
  headerVariant = 'home',
  footerVariant = 'default',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header variant={headerVariant} />
    <main id="main">
      <slot />
    </main>
    <Footer variant={footerVariant} />
    {/* Vercel Web Analytics — cookieless page-view + visitor counting.
        No-ops in dev; sends to /_vercel/insights only on the Vercel deploy
        (Web Analytics must be enabled for the project in the Vercel dashboard). */}
    <Analytics />
  </body>
</html>
