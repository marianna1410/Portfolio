---
import { Image } from 'astro:assets';
// Hero assets
import skyBg     from '../assets/hero/hero-sky-bg.png';
import avatar    from '../assets/hero/hero-avatar.png';
import heroPaper from '../assets/hero/hero-paper.svg';
// Arrow icon for the button
import diagonalArrow from '../assets/icons/diagonal-arrow.svg';
import ArrowSwap from './ArrowSwap.astro';
// Decorative icons — desktop set (10 icons, 256px sources for 4x retina at 64px display)
import iconClaude         from '../assets/icons/icon-claude.png';
import iconClever         from '../assets/icons/icon-clever.png';
import iconEye            from '../assets/icons/icon-eye.png';
import iconFigma          from '../assets/icons/icon-figma.png';
import iconFlash          from '../assets/icons/icon-flash.png';
import iconFlower         from '../assets/icons/icon-flower.png';
import iconGemini         from '../assets/icons/icon-gemini.png';
import iconGoogleCalendar from '../assets/icons/icon-google-calendar.png';
import iconNotion         from '../assets/icons/icon-notion.png';
import iconSlack          from '../assets/icons/icon-slack.png';
// Decorative icons — mobile set (6 icons, 192px sources for 4x retina at 48px display).
// Mobile uses a different visual layout (3 top + 3 bottom around the card).
import iconClaudeM  from '../assets/icons/icon-claude-mobile.png';
import iconEyeM     from '../assets/icons/icon-eye-mobile.png';
import iconFigmaM   from '../assets/icons/icon-figma-mobile.png';
import iconFlowerM  from '../assets/icons/icon-flower-mobile.png';
import iconGeminiM  from '../assets/icons/icon-gemini-mobile.png';
import iconNotionM  from '../assets/icons/icon-notion-mobile.png';

import { RESUME_URL } from '../lib/config.ts';
---

<section class="hero" id="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">

    <!-- ─── Title + tag ──────────────────────────────────── -->
    <div class="hero__title-group">
      <p class="hero__tag text-caption-mono">{`{OPEN TO WORK}`}</p>
      <h1 id="hero-heading" class="hero__heading text-h1">
        Designer Who Creates Digital Experiences for Humans
      </h1>
    </div>

    <!-- ─── Card area: icons + resume card ───────────────── -->
    <div class="hero__card-area">

      <!-- Decorative icons — DESKTOP set (10 icons around the card).
           Hidden on mobile via CSS; mobile uses a separate 6-icon set below.
           Render at 128px (2x retina from 256px source); CSS displays at 64px. -->
      <div class="hero__icons hero__icons--desktop" aria-hidden="true">
        <!-- top row -->
        <Image src={iconClever}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--clever" />
        <Image src={iconGoogleCalendar} alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--google-calendar" />
        <!-- upper sides -->
        <Image src={iconFlower}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--flower" />
        <Image src={iconFigma}          alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--figma" />
        <!-- middle sides -->
        <Image src={iconGemini}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--gemini" />
        <Image src={iconEye}            alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--eye" />
        <!-- lower sides -->
        <Image src={iconClaude}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--claude" />
        <Image src={iconNotion}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--notion" />
        <!-- bottom row -->
        <Image src={iconFlash}          alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--flash" />
        <Image src={iconSlack}          alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--slack" />
      </div>

      <!-- Decorative icons — MOBILE set (6 icons: 3 top + 3 bottom).
           Hidden on desktop via CSS. Visual layout per Figma node 647:23550.
           Render at 96px (2x retina from 192px source); CSS displays at 48px. -->
      <div class="hero__icons hero__icons--mobile" aria-hidden="true">
        <!-- top trio: flower (left) · gemini (center, raised) · claude (right) -->
        <Image src={iconFlowerM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--flower" />
        <Image src={iconGeminiM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--gemini" />
        <Image src={iconClaudeM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--claude" />
        <!-- bottom trio: figma (left) · eye (center, lowered) · notion (right) -->
        <Image src={iconFigmaM}  alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--figma" />
        <Image src={iconEyeM}    alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--eye" />
        <Image src={iconNotionM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--notion" />
      </div>

      <!-- ─── Resume card ──────────────────────────────── -->
      <div class="hero__card">

        <!-- Sky background layer (decorative).
             Render at 522×662 (2x retina from 1044×1324 source); CSS displays at 261×331. -->
        <div class="hero__sky-wrap" aria-hidden="true">
          <Image src={skyBg} alt="" width={522} height={662} quality={90} class="hero__sky-img" />
        </div>

        <!-- Paper layer (card face with shadow).
             box-shadow is on the IMG (filter: drop-shadow) so the shadow follows
             the SVG silhouette including the punched circle holes — per Figma. -->
        <div class="hero__paper-wrap">
          {/* White fill behind the two punched circles in the paper SVG.
              Sky-wrap starts at x=39 within the card, but the punches are at
              x=26 → without these, orbiting icons (which sit behind the card)
              show through the holes. Painted BEFORE the paper image so they
              live behind it; the paper SVG's own drop-shadow still renders
              into the hole rims so they keep their "punched" look. */}
          <span class="hero__paper-hole hero__paper-hole--top" aria-hidden="true"></span>
          <span class="hero__paper-hole hero__paper-hole--bottom" aria-hidden="true"></span>
          <Image
            src={heroPaper}
            alt=""
            width={338}
            height={330}
            class="hero__paper-img"
            aria-hidden="true"
          />

          <!-- Avatar — 224×224 source rendered for 2x retina at 112px display -->
          <div class="hero__avatar" aria-hidden="true">
            <Image
              src={avatar}
              alt=""
              width={224}
              height={224}
              quality={90}
              class="hero__avatar-img"
            />
          </div>

          <!-- Open Resume button -->
          <a
            href={RESUME_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="hero__resume-btn text-label"
            aria-label="Open Resume (opens in new tab)"
          >
            <span>Open Resume</span>
            <ArrowSwap icon={diagonalArrow} class="hero__resume-btn-icon" />
          </a>

          <!-- Caption -->
          <p class="hero__caption text-caption-mono">
            UX/UI Designer · 2+ years crafting<br />user&#8209;friendly interfaces
          </p>
        </div>
      </div>
      <!-- end .hero__card -->

    </div>
    <!-- end .hero__card-area -->

  </div>
</section>

<style>
  /* ====== Section shell ====== */
  .hero {
    min-height: 800px;
    padding-top: 145px;      /* content starts at y=145 per Figma */
    padding-bottom: 64px;
    padding-inline: var(--container-padding-desktop);
  }

  @media (min-width: 768px) and (max-width: 1279px) {
    .hero {
      padding-inline: var(--container-padding-tablet);
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: auto;
      /* Visual gap of 48px between Header pill bottom and {OPEN TO WORK}.
         Header is position:sticky with top:20px (mobile), so it overlaps hero
         by 20px in the layout flow. To get 48px visual gap: padding-top = 48 + 20 = 68. */
      padding-top: 68px;
      padding-bottom: var(--space-stack-5xl); /* 32px mobile — matches Works section */
      padding-inline: var(--container-padding-mobile);
    }
  }

  /* ====== Inner flex column ====== */
  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  /* ====== Title + tag ====== */
  .hero__title-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-stack-xl);
    text-align: center;
    max-width: 766px;
    width: 100%;
  }

  .hero__tag {
    color: var(--color-text-grey-muted);
  }

  .hero__heading {
    color: var(--color-text-black);
  }

  /* ====== Card area (icons + card container) ====== */
  .hero__card-area {
    position: relative;
    width: 679px;
    height: 348px;
    flex-shrink: 0;
  }

  /* ====== Decorative icons — desktop (64px) ====== */
  .hero__icons {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__icon {
    position: absolute;
    width: 64px;
    height: 64px;
    display: block;
    /* Parent .hero__icons has pointer-events:none so clicks pass through to
       the resume card. Icons themselves opt back in so the orbit-pause +
       scale-up hover (animations.md §4.2) can fire. */
    pointer-events: auto;
    will-change: transform;
  }

  /* Absolute positions per Figma node 472:16030 */
  .hero__icon--clever          { left: 226px; top: 0;     }
  .hero__icon--google-calendar { left: 388px; top: 0;     }
  .hero__icon--flower          { left: 68px;  top: 30px;  }
  .hero__icon--figma           { left: 546px; top: 30px;  }
  .hero__icon--gemini          { left: 0;     top: 130px; }
  .hero__icon--eye             { left: 615px; top: 130px; }
  .hero__icon--claude          { left: 68px;  top: 230px; }
  .hero__icon--notion          { left: 546px; top: 230px; }
  .hero__icon--flash           { left: 226px; top: 284px; }
  .hero__icon--slack           { left: 388px; top: 284px; }

  /* ====== Resume card ====== */
  .hero__card {
    position: absolute;
    left: 170px;  /* centers the 338px card within 679px container */
    top: 0;
    width: 338px;
    height: 349px;
  }

  /* Sky background (behind the paper card) */
  .hero__sky-wrap {
    position: absolute;
    left: 39px;
    top: 0;
    width: 261px;
    height: 331px;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .hero__sky-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  /* Paper layer — white card face with shadow.
     border-radius removed from wrapper (paper SVG has its own rounded shape).
     Shadow is on the IMG via filter: drop-shadow — this follows the SVG
     silhouette so the shadow also appears INSIDE the two punched holes
     (matches Figma "paper" effect). */
  .hero__paper-wrap {
    position: absolute;
    left: 0;
    top: 19px;
    width: 338px;
    height: 330px;
  }

  /* Hole-fillers. Coords come straight from the SVG (viewBox 338×330):
     centers at (26, 26) and (26, 62), each with radius 10. The 20×20
     square is offset 10px back from the center → top-left at (16, 16)
     and (16, 52). Mobile paper-wrap is 292×289 (≈0.864× scale), so
     mobile values are scaled proportionally below. */
  .hero__paper-hole {
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: var(--color-bg-white);
    pointer-events: none;
  }
  .hero__paper-hole--top    { left: 16px; top: 16px; }
  .hero__paper-hole--bottom { left: 16px; top: 52px; }

  .hero__paper-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    /* Chained drop-shadows mirror --shadow-card from tokens.css.
       Third layer (rgba 0) skipped — would be invisible. */
    filter:
      drop-shadow(-2px 2px 2px rgba(0, 0, 0, 0.05))
      drop-shadow(-4px 3px 2px rgba(0, 0, 0, 0.012));
  }

  /* Avatar circle */
  .hero__avatar {
    position: absolute;
    left: 50%;
    top: 32px;
    transform: translateX(-50%);
    width: 112px;
    height: 112px;
    border-radius: var(--radius-pill);
    overflow: hidden;
    background-color: var(--color-bg-grey-muted);
    flex-shrink: 0;
  }

  .hero__avatar-img {
    display: block;
    width: 112px;
    height: 112px;
    object-fit: cover;
    object-position: top center;
  }

  /* Open Resume button */
  .hero__resume-btn {
    position: absolute;
    left: 50%;
    top: 172px;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: var(--space-inset-sm);  /* 8px */
    height: 32px;
    padding-top: var(--space-inset-xs);
    padding-bottom: var(--space-inset-xs);
    padding-left: var(--space-inset-lg);
    padding-right: var(--space-inset-md);
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-stroke-medium-grey);
    border-radius: var(--radius-l);
    color: var(--color-text-dark-grey);
    white-space: nowrap;
    transition: border-color var(--duration-fast) var(--ease-out); /* 150ms */
  }

  /* Hover: border darkens to stroke/dark-grey. Pointer-only — no hover
     on touch. */
  @media (hover: hover) and (pointer: fine) {
    .hero__resume-btn:hover {
      border-color: var(--color-stroke-dark-grey);
    }
  }

  .hero__resume-btn-icon {
    display: block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Optical text alignment — Inter Tight has tall ascenders, so flex-centered
     text reads ~1-2px higher than the mathematical center of the line-box.
     translateY pulls the text down so its visual center (between cap-line and
     baseline) aligns with the icon's visual center (matches Figma). */
  .hero__resume-btn span {
    transform: translateY(1px);
  }

  /* Touch devices: intentionally NO min-height override here. WCAG 2.5.5
     recommends 44×44 tap targets, but Marianna's call is to keep the
     32px height on phones too — the button sits in the centre of the
     hero card with no neighbouring clickable elements, so accidental
     mis-taps aren't a risk and the optical mismatch between desktop
     (32px) and Android (was 44px) goes away. */

  /* Caption */
  .hero__caption {
    position: absolute;
    left: 50%;
    top: 274px;
    transform: translateX(-50%);
    width: 306px;
    text-align: center;
    color: var(--color-text-grey-muted);
  }

  /* ============================================================
     Desktop / Mobile icon-set toggle
     ============================================================ */
  .hero__icons--mobile { display: none; } /* hidden on desktop */

  /* ============================================================
     Mobile (≤767px) — per Figma node 647:23550 (375px frame).
     Card 294×304px, card-area 343×490px (icons extend above and
     below the card visually). All coordinates match Figma exactly.
     ============================================================ */

  @media (max-width: 767px) {
    /* Inner column gap on mobile — 32px between title group and card area
       (per Figma node 647:21901: title-group bottom y=134, resume-card-icons y=166 → 32px) */
    .hero__inner {
      gap: 32px;
    }

    /* Title group gap between {OPEN TO WORK} tag and h1 (Figma: 12px) */
    .hero__title-group {
      gap: var(--space-stack-md); /* 8px mobile — close to Figma 12px */
    }

    /* Card-area: full container width 343px (=375 viewport - 2×16 page margin)
       Height 490px accommodates icons that visually extend past the card.
       Per Figma frame 647:21905. */
    .hero__card-area {
      width: 343px;
      height: 490px;
    }

    /* Swap icon sets: hide desktop 10-icon set, show mobile 6-icon set */
    .hero__icons--desktop { display: none; }

    /* Mobile icons skip the orbital wobble — desktop-only animation. */
    .hero__icon-m {
      pointer-events: auto;
    }
    .hero__icons--mobile  { display: block; }

    /* Mobile icons base: 48px (sourced from 192px PNG for 4x retina) */
    .hero__icon-m {
      position: absolute;
      width: 48px;
      height: 48px;
      display: block;
    }

    /* Mobile icon positions per Figma frames 647:21921 (top) + 647:22186 (bottom).
       All Y coords use a +10 shift from raw Figma (raw top-icons frame y=-10)
       so nothing is negative in CSS. Card top also gets +10 (y=88 vs Figma 78).
       Gap between top icons bottom and card top = 10px (matches Figma). */
    /* Top trio — flower (left) · gemini (raised center) · claude (right) */
    .hero__icon-m--flower { left: 24px;  top: 30px;  }
    .hero__icon-m--gemini { left: 148px; top: 0;     }
    .hero__icon-m--claude { left: 270px; top: 30px;  }
    /* Bottom trio — figma (left) · eye (lowered center) · notion (right) */
    .hero__icon-m--figma  { left: 25px;  top: 412px; }
    .hero__icon-m--eye    { left: 147px; top: 442px; }
    .hero__icon-m--notion { left: 270px; top: 412px; }

    /* Gentle bottom-up float (Marianna): each icon drifts ~6px (≈12% of
       its 48px size) over 4s, ease-in-out. Per-icon negative delays
       distribute the phases across the cycle so the six icons read as
       independent floats — like bubbles on water — instead of moving
       in lockstep. Pure CSS; cheaper than a JS RAF loop on mobile.
       transform-only animation keeps it on the GPU. */
    .hero__icon-m {
      animation: hero-mobile-float 4s ease-in-out infinite;
      will-change: transform;
    }
    .hero__icon-m--flower { animation-delay: 0s;    }
    .hero__icon-m--gemini { animation-delay: -0.7s; }
    .hero__icon-m--claude { animation-delay: -1.4s; }
    .hero__icon-m--figma  { animation-delay: -2.0s; }
    .hero__icon-m--eye    { animation-delay: -2.7s; }
    .hero__icon-m--notion { animation-delay: -3.3s; }

    @media (prefers-reduced-motion: reduce) {
      .hero__icon-m { animation: none; }
    }
  }

  /* Keyframes need to live OUTSIDE the @media block because some browsers
     scope @keyframes by media context. Putting them in the global scope
     guarantees the animation reference resolves on mobile. */
  @keyframes hero-mobile-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  /* (Re-open the mobile @media so the closing brace below still matches.
     Trailing rules continue inside the same media query below.) */
  @media (max-width: 767px) {

    /* Card: positioned at x=24, y=88 within card-area (Figma y=78, shifted +10
       to leave room for top icons which extended above the original Figma frame) */
    .hero__card {
      position: absolute;
      left: 24px;
      top: 88px;
      width: 294px;
      height: 304px;
    }

    /* Sky background: 206×300, centered in 294px card (left:44, gap each side 44).
       Figma spec: 206×304, but paper SVG (viewBox 338×330) preserves aspect ratio
       inside the 292×289 paper-wrap and renders ~285px tall. Sky shortened to 300
       so its bottom matches paper's visual bottom — no blue strip leaking below. */
    .hero__sky-wrap {
      left: 44px;
      top: 0;
      width: 206px;
      height: 300px;
    }

    /* Paper layer: 292×289 at x=1, y=15 within card */
    .hero__paper-wrap {
      left: 1px;
      top: 15px;
      width: 292px;
      height: 289px;
    }

    /* Hole-fillers scale to paper (0.864× of desktop SVG): 17px ⌀,
       centers at (22.5, 22.5) and (22.5, 54.3) → top-left rounded. */
    .hero__paper-hole {
      width: 17px;
      height: 17px;
    }
    .hero__paper-hole--top    { left: 14px; top: 14px; }
    .hero__paper-hole--bottom { left: 14px; top: 46px; }

    /* Avatar: 92×92 at x=100, y=28 within paper (centered: 100+46=146=292/2) */
    .hero__avatar {
      top: 28px;
      width: 92px;
      height: 92px;
    }

    .hero__avatar-img {
      width: 92px;
      height: 92px;
    }

    /* "Open Resume" button: top:140 within paper. Width auto-sizes to content. */
    .hero__resume-btn {
      top: 140px;
      gap: var(--space-inset-xs);
      padding-left: var(--space-inset-md);
      padding-right: var(--space-inset-sm);
    }

    /* Arrow shrinks to 16px on mobile. ArrowSwap renders its own scoped
       elements, so reach into them with :global from the (scoped) button. */
    .hero__resume-btn-icon,
    .hero__resume-btn :global(.arrow-swap),
    .hero__resume-btn :global(.arrow-swap-icon) {
      width: 16px;
      height: 16px;
    }

    /* Caption: 268px wide at x=12, y=243 within paper.
       Font-size 12px via --font-size-caption-mono mobile override. */
    .hero__caption {
      top: 243px;
      width: 268px;
    }
  }
</style>

<script>
  /* Hero icon orbit (animations.md §4.1 + §4.2).
     All 10 desktop icons share ONE elliptical orbit (rx=290, ry=145)
     around the resume card's center. Two non-obvious things in here:

     1) ARC-LENGTH parameterization. A naïve (rx·cos t, ry·sin t) at
        constant dt/dt moves the icon FASTER near the short-axis ends and
        SLOWER near the long-axis ends (because the ellipse stretches the
        parameter space). Visually adjacent icons appeared to "breathe"
        — distance swelling and shrinking each lap, sometimes overlapping.
        Fix: pre-compute an arc-length table and step every icon by equal
        ARC LENGTH per frame. Then the chord between adjacent icons
        stays roughly constant (~140px for 10 slots on this ellipse).

     2) Even arc-length slots, NOT even angles. Icons are sorted by their
        Figma angular position and assigned slots 0..9 in that order; each
        slot lives at slot/N of the total perimeter. Preserves rough order
        so the initial snap-in is minimal.

     Hover: pause the master tween (one tween drives all icons), scale
     the hovered icon 1.15× (250ms ease-out). Leave: reverse + resume.
     Mobile icons stay static. Reduced motion: no snap-in, no orbit, no
     hover scale — icons stay at Figma positions per accessibility.md. */
  import { gsap } from 'gsap';

  type OrbitTween = ReturnType<typeof gsap.to>;
  let orbitTweens: OrbitTween[] = [];

  const RX = 290;             // px — horizontal semi-axis
  const RY = 145;             // px — vertical semi-axis
  const BASE_PERIOD = 22;     // s — full revolution (meditative pace)
  const SNAP_DURATION = 0.8;  // s — initial slide from Figma → orbit
  const HOVER_SCALE = 1.15;
  const HOVER_DURATION = 0.25;
  const ARC_SAMPLES = 360;    // resolution of arc-length lookup table

  function killOrbit() {
    orbitTweens.forEach((t) => t.kill());
    orbitTweens = [];
  }

  type ArcSample = { t: number; s: number };
  function buildArcTable(rx: number, ry: number, samples: number): { table: ArcSample[]; total: number } {
    const dt = (2 * Math.PI) / samples;
    const table: ArcSample[] = [{ t: 0, s: 0 }];
    let s = 0;
    let prevX = rx;
    let prevY = 0;
    for (let i = 1; i <= samples; i++) {
      const t = i * dt;
      const x = rx * Math.cos(t);
      const y = ry * Math.sin(t);
      s += Math.hypot(x - prevX, y - prevY);
      table.push({ t, s });
      prevX = x;
      prevY = y;
    }
    return { table, total: s };
  }

  // Binary-search the arc table for parameter t at a given arc length s.
  function paramAtArcLength(table: ArcSample[], total: number, targetS: number): number {
    let s = targetS % total;
    if (s < 0) s += total;
    let lo = 0;
    let hi = table.length - 1;
    while (lo < hi) {
      const mid = (lo + hi) >> 1;
      if (table[mid].s < s) lo = mid + 1;
      else hi = mid;
    }
    if (lo === 0) return 0;
    const a = table[lo - 1];
    const b = table[lo];
    const frac = (s - a.s) / (b.s - a.s || 1);
    return a.t + frac * (b.t - a.t);
  }

  function initHeroOrbit() {
    const cardArea = document.querySelector<HTMLElement>('.hero__card-area');
    const icons = Array.from(
      document.querySelectorAll<HTMLElement>('.hero__icons--desktop .hero__icon'),
    );
    if (!cardArea || icons.length === 0) return;

    killOrbit();
    icons.forEach((el) => gsap.set(el, { clearProps: 'transform' }));

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const rect = cardArea.getBoundingClientRect();
    const centerX = rect.width / 2;
    const centerY = rect.height / 2;

    const { table: arcTable, total: arcLength } = buildArcTable(RX, RY, ARC_SAMPLES);

    type IconInfo = {
      el: HTMLElement;
      cssX: number;
      cssY: number;
      originalAngle: number;
      offsetS: number;          // arc-length offset = this icon's slot * (arcLength / N)
      targetX: number;
      targetY: number;
    };
    const data: IconInfo[] = icons.map((el) => {
      const cssX = el.offsetLeft + el.offsetWidth / 2 - centerX;
      const cssY = el.offsetTop + el.offsetHeight / 2 - centerY;
      let angle = Math.atan2(cssY, cssX);
      if (angle < 0) angle += Math.PI * 2;
      return { el, cssX, cssY, originalAngle: angle, offsetS: 0, targetX: 0, targetY: 0 };
    });

    // Assign arc-length slots in original-angle order so each icon barely shifts.
    [...data]
      .sort((a, b) => a.originalAngle - b.originalAngle)
      .forEach((item, slot) => {
        item.offsetS = (slot / icons.length) * arcLength;
        const t = paramAtArcLength(arcTable, arcLength, item.offsetS);
        item.targetX = RX * Math.cos(t);
        item.targetY = RY * Math.sin(t);
      });

    // Phase 1: per-icon snap-in from Figma → orbit slot.
    data.forEach((info) => {
      gsap.fromTo(
        info.el,
        { x: 0, y: 0 },
        {
          x: info.targetX - info.cssX,
          y: info.targetY - info.cssY,
          duration: SNAP_DURATION,
          ease: 'power2.out',
        },
      );
    });

    // Phase 2: ONE master tween advances arc-length progress; onUpdate
    // positions every icon. Single tween = clean pause/resume on hover.
    const state = { progress: 0 };
    const masterTween = gsap.to(state, {
      progress: 1,
      duration: BASE_PERIOD,
      ease: 'none',           // linear — ease-in-out hitches at the loop seam
      repeat: -1,
      delay: SNAP_DURATION,
      onUpdate: () => {
        const advance = state.progress * arcLength;
        for (const info of data) {
          const s = info.offsetS + advance;
          const t = paramAtArcLength(arcTable, arcLength, s);
          const x = RX * Math.cos(t);
          const y = RY * Math.sin(t);
          gsap.set(info.el, { x: x - info.cssX, y: y - info.cssY });
        }
      },
    });
    orbitTweens.push(masterTween);

    data.forEach(({ el }) => {
      el.addEventListener('mouseenter', () => {
        masterTween.pause();
        gsap.to(el, {
          scale: HOVER_SCALE,
          duration: HOVER_DURATION,
          ease: 'power2.out',
          overwrite: 'auto',
        });
      });
      el.addEventListener('mouseleave', () => {
        gsap.to(el, {
          scale: 1,
          duration: HOVER_DURATION,
          ease: 'power2.out',
          overwrite: 'auto',
        });
        masterTween.resume();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroOrbit);
  } else {
    initHeroOrbit();
  }
  document.addEventListener('astro:page-load', initHeroOrbit);
</script>
