---
import { Image } from 'astro:assets';
// Hero assets
import skyBg     from '../assets/hero/hero-sky-bg.png';
import avatar    from '../assets/hero/hero-avatar.png';
import heroPaper from '../assets/hero/hero-paper.svg';
// Arrow icon for the button
import diagonalArrow from '../assets/icons/diagonal-arrow.svg';
import ArrowSwap from './ArrowSwap.astro';
// Decorative icons — desktop set (10 icons, 256px sources for 4x retina at 64px display)
import iconClaude         from '../assets/icons/icon-claude.png';
import iconClever         from '../assets/icons/icon-clever.png';
import iconEye            from '../assets/icons/icon-eye.png';
import iconFigma          from '../assets/icons/icon-figma.png';
import iconFlash          from '../assets/icons/icon-flash.png';
import iconFlower         from '../assets/icons/icon-flower.png';
import iconGemini         from '../assets/icons/icon-gemini.png';
import iconGoogleCalendar from '../assets/icons/icon-google-calendar.png';
import iconNotion         from '../assets/icons/icon-notion.png';
import iconSlack          from '../assets/icons/icon-slack.png';
// Decorative icons — mobile set (6 icons, 192px sources for 4x retina at 48px display).
// Mobile uses a different visual layout (3 top + 3 bottom around the card).
import iconClaudeM  from '../assets/icons/icon-claude-mobile.png';
import iconEyeM     from '../assets/icons/icon-eye-mobile.png';
import iconFigmaM   from '../assets/icons/icon-figma-mobile.png';
import iconFlowerM  from '../assets/icons/icon-flower-mobile.png';
import iconGeminiM  from '../assets/icons/icon-gemini-mobile.png';
import iconNotionM  from '../assets/icons/icon-notion-mobile.png';

import { RESUME_URL } from '../lib/config.ts';
---

<section class="hero" id="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">

    <!-- ─── Title + tag ──────────────────────────────────── -->
    <div class="hero__title-group">
      <p class="hero__tag text-caption-mono">{`{OPEN TO WORK}`}</p>
      <h1 id="hero-heading" class="hero__heading text-h1">
        Designer Who Creates Digital Experiences for Humans
      </h1>
    </div>

    <!-- ─── Card area: icons + resume card ───────────────── -->
    <div class="hero__card-area">

      <!-- Decorative icons — DESKTOP set (10 icons around the card).
           Hidden on mobile via CSS; mobile uses a separate 6-icon set below.
           Render at 128px (2x retina from 256px source); CSS displays at 64px. -->
      <div class="hero__icons hero__icons--desktop" aria-hidden="true">
        <!-- top row -->
        <Image src={iconClever}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--clever" />
        <Image src={iconGoogleCalendar} alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--google-calendar" />
        <!-- upper sides -->
        <Image src={iconFlower}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--flower" />
        <Image src={iconFigma}          alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--figma" />
        <!-- middle sides -->
        <Image src={iconGemini}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--gemini" />
        <Image src={iconEye}            alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--eye" />
        <!-- lower sides -->
        <Image src={iconClaude}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--claude" />
        <Image src={iconNotion}         alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--notion" />
        <!-- bottom row -->
        <Image src={iconFlash}          alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--flash" />
        <Image src={iconSlack}          alt="" width={128} height={128} quality={90} class="hero__icon hero__icon--slack" />
      </div>

      <!-- Decorative icons — MOBILE set (6 icons: 3 top + 3 bottom).
           Hidden on desktop via CSS. Visual layout per Figma node 647:23550.
           Render at 96px (2x retina from 192px source); CSS displays at 48px. -->
      <div class="hero__icons hero__icons--mobile" aria-hidden="true">
        <!-- top trio: flower (left) · gemini (center, raised) · claude (right) -->
        <Image src={iconFlowerM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--flower" />
        <Image src={iconGeminiM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--gemini" />
        <Image src={iconClaudeM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--claude" />
        <!-- bottom trio: figma (left) · eye (center, lowered) · notion (right) -->
        <Image src={iconFigmaM}  alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--figma" />
        <Image src={iconEyeM}    alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--eye" />
        <Image src={iconNotionM} alt="" width={96} height={96} quality={90} class="hero__icon-m hero__icon-m--notion" />
      </div>

      <!-- ─── Resume card ──────────────────────────────── -->
      <div class="hero__card">

        <!-- Sky background layer (decorative).
             Render at 522×662 (2x retina from 1044×1324 source); CSS displays at 261×331. -->
        <div class="hero__sky-wrap" aria-hidden="true">
          <Image src={skyBg} alt="" width={522} height={662} quality={90} class="hero__sky-img" />
        </div>

        <!-- Paper layer (card face with shadow).
             box-shadow is on the IMG (filter: drop-shadow) so the shadow follows
             the SVG silhouette including the punched circle holes — per Figma. -->
        <div class="hero__paper-wrap">
          <Image
            src={heroPaper}
            alt=""
            width={338}
            height={330}
            class="hero__paper-img"
            aria-hidden="true"
          />

          <!-- Avatar — 224×224 source rendered for 2x retina at 112px display -->
          <div class="hero__avatar" aria-hidden="true">
            <Image
              src={avatar}
              alt=""
              width={224}
              height={224}
              quality={90}
              class="hero__avatar-img"
            />
          </div>

          <!-- Open Resume button -->
          <a
            href={RESUME_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="hero__resume-btn text-label"
            aria-label="Open Resume (opens in new tab)"
          >
            <span>Open Resume</span>
            <ArrowSwap icon={diagonalArrow} class="hero__resume-btn-icon" />
          </a>

          <!-- Caption -->
          <p class="hero__caption text-caption-mono">
            UX/UI Designer · 2+ years crafting<br />user&#8209;friendly interfaces
          </p>
        </div>
      </div>
      <!-- end .hero__card -->

    </div>
    <!-- end .hero__card-area -->

  </div>
</section>

<style>
  /* ====== Section shell ====== */
  .hero {
    min-height: 800px;
    padding-top: 145px;      /* content starts at y=145 per Figma */
    padding-bottom: 64px;
    padding-inline: var(--container-padding-desktop);
  }

  @media (min-width: 768px) and (max-width: 1279px) {
    .hero {
      padding-inline: var(--container-padding-tablet);
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: auto;
      /* Visual gap of 48px between Header pill bottom and {OPEN TO WORK}.
         Header is position:sticky with top:20px (mobile), so it overlaps hero
         by 20px in the layout flow. To get 48px visual gap: padding-top = 48 + 20 = 68. */
      padding-top: 68px;
      padding-bottom: var(--space-stack-5xl); /* 32px mobile — matches Works section */
      padding-inline: var(--container-padding-mobile);
    }
  }

  /* ====== Inner flex column ====== */
  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 48px;
  }

  /* ====== Title + tag ====== */
  .hero__title-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-stack-xl);
    text-align: center;
    max-width: 766px;
    width: 100%;
  }

  .hero__tag {
    color: var(--color-text-grey-muted);
  }

  .hero__heading {
    color: var(--color-text-black);
  }

  /* ====== Card area (icons + card container) ====== */
  .hero__card-area {
    position: relative;
    width: 679px;
    height: 348px;
    flex-shrink: 0;
  }

  /* ====== Decorative icons — desktop (64px) ====== */
  .hero__icons {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__icon {
    position: absolute;
    width: 64px;
    height: 64px;
    display: block;
  }

  /* Absolute positions per Figma node 472:16030 */
  .hero__icon--clever          { left: 226px; top: 0;     }
  .hero__icon--google-calendar { left: 388px; top: 0;     }
  .hero__icon--flower          { left: 68px;  top: 30px;  }
  .hero__icon--figma           { left: 546px; top: 30px;  }
  .hero__icon--gemini          { left: 0;     top: 130px; }
  .hero__icon--eye             { left: 615px; top: 130px; }
  .hero__icon--claude          { left: 68px;  top: 230px; }
  .hero__icon--notion          { left: 546px; top: 230px; }
  .hero__icon--flash           { left: 226px; top: 284px; }
  .hero__icon--slack           { left: 388px; top: 284px; }

  /* ====== Resume card ====== */
  .hero__card {
    position: absolute;
    left: 170px;  /* centers the 338px card within 679px container */
    top: 0;
    width: 338px;
    height: 349px;
  }

  /* Sky background (behind the paper card) */
  .hero__sky-wrap {
    position: absolute;
    left: 39px;
    top: 0;
    width: 261px;
    height: 331px;
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .hero__sky-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  /* Paper layer — white card face with shadow.
     border-radius removed from wrapper (paper SVG has its own rounded shape).
     Shadow is on the IMG via filter: drop-shadow — this follows the SVG
     silhouette so the shadow also appears INSIDE the two punched holes
     (matches Figma "paper" effect). */
  .hero__paper-wrap {
    position: absolute;
    left: 0;
    top: 19px;
    width: 338px;
    height: 330px;
  }

  .hero__paper-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    /* Chained drop-shadows mirror --shadow-card from tokens.css.
       Third layer (rgba 0) skipped — would be invisible. */
    filter:
      drop-shadow(-2px 2px 2px rgba(0, 0, 0, 0.05))
      drop-shadow(-4px 3px 2px rgba(0, 0, 0, 0.012));
  }

  /* Avatar circle */
  .hero__avatar {
    position: absolute;
    left: 50%;
    top: 32px;
    transform: translateX(-50%);
    width: 112px;
    height: 112px;
    border-radius: var(--radius-pill);
    overflow: hidden;
    background-color: var(--color-bg-grey-muted);
    flex-shrink: 0;
  }

  .hero__avatar-img {
    display: block;
    width: 112px;
    height: 112px;
    object-fit: cover;
    object-position: top center;
  }

  /* Open Resume button */
  .hero__resume-btn {
    position: absolute;
    left: 50%;
    top: 172px;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: var(--space-inset-sm);  /* 8px */
    height: 32px;
    padding-top: var(--space-inset-xs);
    padding-bottom: var(--space-inset-xs);
    padding-left: var(--space-inset-lg);
    padding-right: var(--space-inset-md);
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-stroke-medium-grey);
    border-radius: var(--radius-l);
    color: var(--color-text-dark-grey);
    white-space: nowrap;
    transition: border-color var(--duration-fast) var(--ease-out); /* 150ms */
  }

  /* Hover: border darkens to stroke/dark-grey. Pointer-only — no hover
     on touch. */
  @media (hover: hover) and (pointer: fine) {
    .hero__resume-btn:hover {
      border-color: var(--color-stroke-dark-grey);
    }
  }

  .hero__resume-btn-icon {
    display: block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Optical text alignment — Inter Tight has tall ascenders, so flex-centered
     text reads ~1-2px higher than the mathematical center of the line-box.
     translateY pulls the text down so its visual center (between cap-line and
     baseline) aligns with the icon's visual center (matches Figma). */
  .hero__resume-btn span {
    transform: translateY(1px);
  }

  /* Touch devices — 44px minimum tap target */
  @media (pointer: coarse) {
    .hero__resume-btn {
      min-height: 44px;
    }
  }

  /* Caption */
  .hero__caption {
    position: absolute;
    left: 50%;
    top: 274px;
    transform: translateX(-50%);
    width: 306px;
    text-align: center;
    color: var(--color-text-grey-muted);
  }

  /* ============================================================
     Desktop / Mobile icon-set toggle
     ============================================================ */
  .hero__icons--mobile { display: none; } /* hidden on desktop */

  /* ============================================================
     Mobile (≤767px) — per Figma node 647:23550 (375px frame).
     Card 294×304px, card-area 343×490px (icons extend above and
     below the card visually). All coordinates match Figma exactly.
     ============================================================ */

  @media (max-width: 767px) {
    /* Inner column gap on mobile — 32px between title group and card area
       (per Figma node 647:21901: title-group bottom y=134, resume-card-icons y=166 → 32px) */
    .hero__inner {
      gap: 32px;
    }

    /* Title group gap between {OPEN TO WORK} tag and h1 (Figma: 12px) */
    .hero__title-group {
      gap: var(--space-stack-md); /* 8px mobile — close to Figma 12px */
    }

    /* Card-area: full container width 343px (=375 viewport - 2×16 page margin)
       Height 490px accommodates icons that visually extend past the card.
       Per Figma frame 647:21905. */
    .hero__card-area {
      width: 343px;
      height: 490px;
    }

    /* Swap icon sets: hide desktop 10-icon set, show mobile 6-icon set */
    .hero__icons--desktop { display: none; }
    .hero__icons--mobile  { display: block; }

    /* Mobile icons base: 48px (sourced from 192px PNG for 4x retina) */
    .hero__icon-m {
      position: absolute;
      width: 48px;
      height: 48px;
      display: block;
    }

    /* Mobile icon positions per Figma frames 647:21921 (top) + 647:22186 (bottom).
       All Y coords use a +10 shift from raw Figma (raw top-icons frame y=-10)
       so nothing is negative in CSS. Card top also gets +10 (y=88 vs Figma 78).
       Gap between top icons bottom and card top = 10px (matches Figma). */
    /* Top trio — flower (left) · gemini (raised center) · claude (right) */
    .hero__icon-m--flower { left: 24px;  top: 30px;  }
    .hero__icon-m--gemini { left: 148px; top: 0;     }
    .hero__icon-m--claude { left: 270px; top: 30px;  }
    /* Bottom trio — figma (left) · eye (lowered center) · notion (right) */
    .hero__icon-m--figma  { left: 25px;  top: 412px; }
    .hero__icon-m--eye    { left: 147px; top: 442px; }
    .hero__icon-m--notion { left: 270px; top: 412px; }

    /* Card: positioned at x=24, y=88 within card-area (Figma y=78, shifted +10
       to leave room for top icons which extended above the original Figma frame) */
    .hero__card {
      position: absolute;
      left: 24px;
      top: 88px;
      width: 294px;
      height: 304px;
    }

    /* Sky background: 206×300, centered in 294px card (left:44, gap each side 44).
       Figma spec: 206×304, but paper SVG (viewBox 338×330) preserves aspect ratio
       inside the 292×289 paper-wrap and renders ~285px tall. Sky shortened to 300
       so its bottom matches paper's visual bottom — no blue strip leaking below. */
    .hero__sky-wrap {
      left: 44px;
      top: 0;
      width: 206px;
      height: 300px;
    }

    /* Paper layer: 292×289 at x=1, y=15 within card */
    .hero__paper-wrap {
      left: 1px;
      top: 15px;
      width: 292px;
      height: 289px;
    }

    /* Avatar: 92×92 at x=100, y=28 within paper (centered: 100+46=146=292/2) */
    .hero__avatar {
      top: 28px;
      width: 92px;
      height: 92px;
    }

    .hero__avatar-img {
      width: 92px;
      height: 92px;
    }

    /* "Open Resume" button: top:140 within paper. Width auto-sizes to content. */
    .hero__resume-btn {
      top: 140px;
      gap: var(--space-inset-xs);
      padding-left: var(--space-inset-md);
      padding-right: var(--space-inset-sm);
    }

    /* Arrow shrinks to 16px on mobile. ArrowSwap renders its own scoped
       elements, so reach into them with :global from the (scoped) button. */
    .hero__resume-btn-icon,
    .hero__resume-btn :global(.arrow-swap),
    .hero__resume-btn :global(.arrow-swap-icon) {
      width: 16px;
      height: 16px;
    }

    /* Caption: 268px wide at x=12, y=243 within paper.
       Font-size 12px via --font-size-caption-mono mobile override. */
    .hero__caption {
      top: 243px;
      width: 268px;
    }
  }
</style>
