---
/**
 * ArrowSwap.astro — diagonal-arrow icon with hover swap.
 *
 * Two identical arrows stacked in a clipped box. On hover of the enclosing
 * link the visible arrow slides out along its own diagonal (top-right) while
 * an identical copy slides in from the opposite corner to land exactly where
 * the first one sat — reads as one continuous diagonal motion. 400ms ease-out.
 *
 * The icon is passed in so colour variants (black / dark-grey) stay per-call.
 * Pass `class` for per-site layout tweaks (e.g. optical margin) — it lands on
 * the wrapper box. Trigger is the nearest ancestor <a>/<button> :hover.
 *
 * animations.md §10.3 / §11.2. Honors prefers-reduced-motion (no movement).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  icon: ImageMetadata;
  size?: number;
  class?: string;
}

const { icon, size = 20, class: className } = Astro.props;
---

<span class:list={['arrow-swap', className]} aria-hidden="true" style={`--arrow-size:${size}px`}>
  <Image src={icon} alt="" width={size} height={size} class="arrow-swap-icon arrow-swap-icon--out" />
  <Image src={icon} alt="" width={size} height={size} class="arrow-swap-icon arrow-swap-icon--in" />
</span>

<style>
  .arrow-swap {
    position: relative;
    display: block;
    width: var(--arrow-size, 20px);
    height: var(--arrow-size, 20px);
    flex-shrink: 0;
    overflow: hidden;
  }

  .arrow-swap-icon {
    position: absolute;
    inset: 0;
    display: block;
    width: var(--arrow-size, 20px);
    height: var(--arrow-size, 20px);
    transition: transform var(--duration-slow) var(--ease-out); /* 400ms */
  }

  /* Incoming copy waits one box down-left, outside the clip area. */
  .arrow-swap-icon--in {
    transform: translate(-100%, 100%);
  }

  /* Keyboard focus drives the swap on any device (focus-visible is
     keyboard-only — a touch tap never triggers it). */
  :global(a):focus-visible .arrow-swap-icon--out,
  :global(button):focus-visible .arrow-swap-icon--out {
    transform: translate(100%, -100%); /* exit top-right */
  }
  :global(a):focus-visible .arrow-swap-icon--in,
  :global(button):focus-visible .arrow-swap-icon--in {
    transform: translate(0, 0); /* slide into default slot */
  }

  /* Hover swap only where there's a real pointer — no sticky :hover on
     touch screens (we don't do hover on mobile). */
  @media (hover: hover) and (pointer: fine) {
    :global(a):hover .arrow-swap-icon--out,
    :global(button):hover .arrow-swap-icon--out {
      transform: translate(100%, -100%);
    }
    :global(a):hover .arrow-swap-icon--in,
    :global(button):hover .arrow-swap-icon--in {
      transform: translate(0, 0);
    }
  }

  /* Reduced motion: global rule only zeroes transition-duration, so the
     arrows would otherwise JUMP. Neutralize the swap — arrow stays put. */
  @media (prefers-reduced-motion: reduce) {
    :global(a):hover .arrow-swap-icon--out,
    :global(a):focus-visible .arrow-swap-icon--out,
    :global(button):hover .arrow-swap-icon--out,
    :global(button):focus-visible .arrow-swap-icon--out {
      transform: none;
    }
    :global(a):hover .arrow-swap-icon--in,
    :global(a):focus-visible .arrow-swap-icon--in,
    :global(button):hover .arrow-swap-icon--in,
    :global(button):focus-visible .arrow-swap-icon--in {
      transform: translate(-100%, 100%);
    }
  }
</style>
