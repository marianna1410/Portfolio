---
import { Image } from 'astro:assets';
import lucidaDefault from '../assets/projects/lucida-default.png';
import vaiaDefault   from '../assets/projects/vaia-default.png';

/**
 * Selected Works data — kept inline here since there are only 2 cases.
 * Tags + titles per Figma node 472:16047. Links route to case study pages.
 */
const works = [
  {
    slug: 'lucida',
    tags: ['Mobile App', 'Language Learning', 'Redesign Concept'],
    title: 'Bringing structure and confidence to speaking practice through proven learning patterns',
    defaultImg: lucidaDefault,
  },
  {
    slug: 'vaia',
    tags: ['Mobile App', 'EdTech', 'Redesign Concept'],
    title: "Restoring students' control and transparency over automated exam preparation",
    defaultImg: vaiaDefault,
  },
];
---

<section class="works" id="works" aria-labelledby="works-heading">
  <div class="works__inner">
    <h2 id="works-heading" class="works__heading text-h2">Selected Works</h2>

    <ul class="works__cards">
      {works.map((work) => (
        <li class="works__card-item">
          {/* data-astro-reload forces a full page load into the case (not a
              client-side View Transition). The Solution after-videos use
              `autoplay`, which only fires on a real page load — after a
              client-side nav the swapped-in <video> stays paused/blank in some
              browsers. A full load makes every case behave like a direct visit. */}
          <a href={`/cases/${work.slug}`} class="works__card" data-astro-reload aria-label={`Open ${work.slug} case study`}>
            <div class="works__card-inner">
              <div class="works__tags-title">
                <ul class="works__tags" aria-label="Project metadata">
                  {work.tags.map((tag) => <li class="works__tag text-caption-mono">{tag}</li>)}
                </ul>
                <h3 class="works__card-title text-h4-medium">{work.title}</h3>
              </div>

              <div class="works__image">
                <Image
                  src={work.defaultImg}
                  alt=""
                  width={1212}
                  height={784}
                  quality={95}
                  class="works__image-img"
                />
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* ====== Section shell ====== */
  .works {
    background-color: var(--color-bg-light-grey);
    padding-block: var(--space-section-block); /* 64px desktop / 44px mobile */
    padding-inline: var(--container-padding-desktop);
  }

  @media (min-width: 768px) and (max-width: 1279px) {
    .works {
      padding-inline: var(--container-padding-tablet);
    }
  }

  @media (max-width: 767px) {
    .works {
      padding-inline: var(--container-padding-mobile);
    }
  }

  /* ====== Inner column ====== */
  .works__inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-stack-5xl); /* 48px desktop */
    max-width: var(--container-max-width);
    margin-inline: auto;
    width: 100%;
  }

  /* Mobile: gap between heading and cards = 32px (new section standard). */
  @media (max-width: 767px) {
    .works__inner {
      gap: var(--space-stack-5xl); /* 32px mobile */
    }
  }

  .works__heading {
    color: var(--color-text-black);
  }

  /* ====== Cards row ====== */
  .works__cards {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-inline-xl); /* 20px desktop / 16px mobile */
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .works__card-item {
    flex: 1 1 calc((100% - var(--space-inline-xl)) / 2);
    min-width: 0; /* allow card to shrink properly */
  }

  /* Mobile: stack cards vertically (per Marianna's brief) */
  @media (max-width: 767px) {
    .works__card-item {
      flex: 1 1 100%;
    }
  }

  /* ====== Card ====== */
  .works__card {
    display: block;
    background-color: var(--color-bg-white);
    border-radius: var(--radius-2xl); /* 20px desktop / 16px mobile */
    padding: var(--space-inset-xl); /* 20px desktop / 16px mobile */
    height: 580px;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .works__card {
      height: auto; /* let mobile cards size to content */
    }
  }

  .works__card-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-3xl); /* 32px desktop / 24px mobile */
    height: 100%;
  }

  /* ====== Tags + title ====== */
  .works__tags-title {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-2xl); /* 24px desktop / 20px mobile */
  }

  .works__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-inline-sm); /* 8px */
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .works__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-inset-sm) var(--space-inset-lg); /* 8px 16px */
    background-color: var(--color-bg-light-grey);
    border-radius: var(--radius-l); /* 12px */
    color: var(--color-text-grey-muted);
    white-space: nowrap;
  }

  .works__card-title {
    color: var(--color-text-black);
    /* Allow title to wrap naturally */
    text-wrap: balance;
  }

  /* ====== Image area with hover zoom (Ken-Burns, matches Next-case card) ====== */
  .works__image {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    border-radius: var(--radius-l); /* 12px */
    background-color: var(--color-bg-light-grey); /* fallback while images load */
  }

  /* Mobile: card height auto, so image needs explicit aspect-ratio
     (~606:392 from Figma 472:16051 image area). */
  @media (max-width: 767px) {
    .works__image {
      flex: 0 0 auto;
      aspect-ratio: 606 / 392;
    }
  }

  /* Single image fills the rounded frame; the frame's overflow:hidden crops
     the gentle Ken-Burns zoom on hover (same effect as the Next-case card). */
  .works__image-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform var(--duration-medium) var(--ease-out); /* 250ms */
  }

  /* Hover: image grows ~6%. Pointer-only — no hover on touch. */
  @media (hover: hover) and (pointer: fine) {
    .works__card:hover .works__image-img {
      transform: scale(1.06);
    }
  }

  /* Respect prefers-reduced-motion — no zoom. */
  @media (prefers-reduced-motion: reduce) {
    .works__image-img {
      transition: none;
    }
  }

  /* ====== Focus ring ====== */
  .works__card:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }
</style>
