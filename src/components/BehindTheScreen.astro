---
import { Image } from 'astro:assets';
// Raw import so we can inline the border SVG (vector-effect="non-scaling-stroke"
// renders inconsistently through <img>; inline SVG works reliably everywhere).
import endBorderSvg       from '../assets/icons/behind-end-border.svg?raw';
import endBorderMobileSvg from '../assets/icons/behind-end-border-mobile.svg?raw';
import heartIcon    from '../assets/icons/heart.png';
import checkboxIcon from '../assets/icons/checkbox-check.svg';
import buildingImg  from '../assets/behind-the-screen/building.png';
import fontanImg    from '../assets/behind-the-screen/fontan.png';
import riverImg     from '../assets/behind-the-screen/river.png';

/**
 * Behind the Screen section — Figma node 472:16885.
 * Four-card grid:
 *  - About me (col 1, both rows)   — torn-paper-cut card with mono bio text
 *  - Traveling 2025 (cols 2-3, r1) — white card with 3 rotated photos
 *  - Latest books (col 2, r2)      — white card with checklist (line-through)
 *  - That's it (col 3, r2)         — dashed-border closing card
 *
 * Card grid 3×2, each cell ~424×280, gap 20px, total 1312×580.
 *
 * About-me card uses behind-paper.svg as a backdrop (scalloped top edge).
 * Mobile: cards stack vertically; "That's it" shrinks with heart + text
 * sitting on the same horizontal line.
 */

const books = ['Predictably Irrational', 'Made to Stick', 'The Art of Systems Thinking'];

const bioParagraphs = [
  "Hello! I'm Marianna. Besides being a designer, I consider myself an explorer because curiosity is one of the traits that have paved the way to who I am today.",
  "When I'm not working, you can find me:",
  '→ reading an interesting book about psychology',
  '→ watching long podcasts and interviews',
  '→ taking new courses',
  '→ listening to music',
  '→ scrolling on Pinterest',
  '→ on the road',
];
---

<section class="behind" id="about" aria-labelledby="behind-heading">
  <div class="behind__inner">
    <h2 id="behind-heading" class="behind__heading text-h2">Behind the Screen</h2>

    <div class="behind__grid">
      <!-- About me — paper card spanning both rows. The scalloped top
           edge is a CSS mask on the inner .behind__paper element. The
           outer <article> holds the filter:drop-shadow only (no mask) —
           splitting mask and filter onto separate elements is required
           because Chrome/Opera clip drop-shadow to the mask's bounding
           box when both are on the same element. -->
      <article class="behind__card behind__card--about">
        <div class="behind__paper">
          <div class="behind__about-text text-body-mono-lg">
            {bioParagraphs.map((p) => <p>{p}</p>)}
          </div>
        </div>
      </article>

      <!-- Traveling 2025 -->
      <article class="behind__card behind__card--travel">
        <div class="behind__travel-head">
          <div class="behind__travel-info">
            <p class="text-caption-regular behind__travel-label">Traveling</p>
            <p class="text-h2 behind__travel-year">2025</p>
          </div>
          <span class="behind__travel-tag text-caption-mono">44° 25′ 55″ N</span>
        </div>
        <div class="behind__travel-photos" data-fan-photos aria-hidden="true">
          <div class="behind__photo behind__photo--river">
            <Image src={riverImg} alt="" width={296} height={368} quality={90} />
          </div>
          <div class="behind__photo behind__photo--fontan">
            <Image src={fontanImg} alt="" width={296} height={368} quality={90} />
          </div>
          <div class="behind__photo behind__photo--building">
            <Image src={buildingImg} alt="" width={404} height={466} quality={90} />
          </div>
        </div>
      </article>

      <!-- Latest books -->
      <article class="behind__card behind__card--books">
        <h3 class="behind__books-title text-h4-medium">The latest books I've read</h3>
        <ul class="behind__books-list" data-strike-list>
          {books.map((book) => (
            <li class="behind__book">
              <Image
                src={checkboxIcon}
                alt=""
                width={20}
                height={20}
                class="behind__book-check"
                aria-hidden="true"
              />
              <span class="behind__book-title text-body-large-regular">{book}</span>
            </li>
          ))}
        </ul>
      </article>

      <!-- That's it -->
      <article class="behind__card behind__card--end">
        {/* Inline SVG borders (class-tagged; styled via :global since Astro's
            scoped CSS doesn't reach set:html nodes). Desktop uses the
            pathLength/non-scaling border; mobile swaps to a border drawn at the
            card's real size (346×66, 16px corners) so the dots wrap the corners
            cleanly without distortion. Breakpoint toggle is in CSS below. */}
        <Fragment set:html={endBorderSvg.replace(
          '<svg',
          '<svg aria-hidden="true" class="behind__end-border behind__end-border--desktop"'
        )} />
        <Fragment set:html={endBorderMobileSvg.replace(
          '<svg',
          '<svg aria-hidden="true" class="behind__end-border behind__end-border--mobile"'
        )} />
        {/* Raw <img> (not Astro Image) so the dotted-heart PNG stays
            sharp — Astro's webp conversion softened the dots. */}
        <img
          src={heartIcon.src}
          width={52}
          height={52}
          class="behind__end-heart"
          alt=""
          aria-hidden="true"
          decoding="async"
        />
        <p class="behind__end-text text-body-mono-lg">
          That&rsquo;s it <strong>˘ᵕ˘</strong>
        </p>
      </article>
    </div>
  </div>
</section>

<style>
  /* ====== Section shell ====== */
  .behind {
    background-color: var(--color-bg-light-grey);
    padding-block: var(--space-section-block); /* 64px desktop / 44px mobile */
    padding-inline: var(--container-padding-desktop);
  }

  @media (min-width: 768px) and (max-width: 1279px) {
    .behind {
      padding-inline: var(--container-padding-tablet);
    }
  }

  @media (max-width: 767px) {
    .behind {
      padding-inline: var(--container-padding-mobile);
    }
  }

  /* ====== Inner column ====== */
  .behind__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-5xl); /* 48px desktop / 32px mobile */
    max-width: 1312px;
    margin-inline: auto;
    width: 100%;
  }

  .behind__heading {
    color: var(--color-text-black);
    margin: 0;
  }

  /* ====== 3×2 grid ====== */
  .behind__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: 280px 280px;
    gap: var(--space-stack-xl); /* 20px */
    width: 100%;
  }

  /* ====== Card base ====== */
  .behind__card {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl); /* 20px desktop / 16px mobile */
    background-color: var(--color-bg-white);
    padding: var(--space-inset-2xl); /* 24px desktop / 20px mobile */
  }

  /* ====== About me — paper card (col 1, rows 1-2) ======

     Built as a normal padded container with a CSS mask that cuts circular
     "teeth" out of the top edge. Mask is a repeated radial-gradient tile:
     each 37px tile holds one 27px-diameter circle centered on the top
     edge, leaving 10px of solid paper between circles (per Marianna's
     spec). Mobile variant: 20px circles → 30px tile.

     Why mask not SVG: the previous SVG overlay didn't adapt cleanly to
     varying card widths (aspect-ratio mismatch + janky absolute text
     positioning). A masked container adapts naturally to any width while
     keeping the same 24px inner padding and consistent scallop density. */
  .behind__card--about {
    --scallop-diameter: 27px;
    --scallop-gap: 10px;
    --scallop-tile: calc(var(--scallop-diameter) + var(--scallop-gap));

    grid-column: 1;
    grid-row: 1 / span 2;
    /* Article itself is transparent — its only visible content is
       .behind__paper. filter:drop-shadow then casts based on the
       child's silhouette without being clipped by the child's mask. */
    background-color: transparent;
    padding: 0;
    overflow: visible;
    /* Exact Figma drop-shadow (node 472:16885). */
    filter:
      drop-shadow(-2px 2px 2px rgba(0, 0, 0, 0.05))
      drop-shadow(-4px 3px 2px rgba(0, 0, 0, 0.01))
      drop-shadow(-6px 4px 2px rgba(0, 0, 0, 0));
  }

  /* Inner paper: holds the white background, scalloped mask, and the
     padding/content. Filter on the parent casts its shadow off this
     element's silhouette. */
  .behind__paper {
    width: 100%;
    height: 100%;
    background-color: var(--color-bg-white);
    border-radius: var(--radius-2xl); /* 20px desktop / 16px mobile */
    /* Per Marianna: 40px sides / 44px bottom on desktop. Top padding
       includes scallop diameter (cutouts eat into the visible area). */
    padding-inline: 40px;
    padding-block-end: 44px;
    padding-block-start: calc(var(--scallop-diameter) + 20px);
    box-sizing: border-box;

    /* Scalloped top edge with HALF-circles at BOTH top corners (Marianna:
       torn edges per Figma). Two radial-gradient layers — a disc anchored to
       each tile's LEFT (0%) and RIGHT (100%) edge — are composited with
       `intersect` so the cut = union of both discs. Adjacent tiles merge into
       full teeth at every interior boundary, while the card's own left/right
       edges clip the outermost discs into clean half-circles.
       `--teeth` tiles fit exactly across 100% width → corners stay half
       circles at any card width (desktop ~424px and mobile both use 11). */
    --teeth: 11;
    --scallop-r: calc(var(--scallop-diameter) / 2);
    mask-image:
      radial-gradient(circle var(--scallop-r) at 0 0,    transparent calc(var(--scallop-r) - 1px), #000 var(--scallop-r)),
      radial-gradient(circle var(--scallop-r) at 100% 0, transparent calc(var(--scallop-r) - 1px), #000 var(--scallop-r));
    mask-size: calc(100% / var(--teeth)) 100%;
    mask-repeat: repeat-x;
    mask-composite: intersect;
    -webkit-mask-image:
      radial-gradient(circle var(--scallop-r) at 0 0,    transparent calc(var(--scallop-r) - 1px), #000 var(--scallop-r)),
      radial-gradient(circle var(--scallop-r) at 100% 0, transparent calc(var(--scallop-r) - 1px), #000 var(--scallop-r));
    -webkit-mask-size: calc(100% / var(--teeth)) 100%;
    -webkit-mask-repeat: repeat-x;
    -webkit-mask-composite: source-in;
  }

  .behind__about-text {
    color: var(--color-text-grey-muted);
  }

  .behind__about-text p {
    margin: 0;
  }

  .behind__about-text p + p {
    margin-top: var(--space-stack-md); /* 12px */
  }

  /* ====== Traveling 2025 (cols 2-3, row 1) ====== */
  .behind__card--travel {
    grid-column: 2 / span 2;
    grid-row: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-inline-2xl); /* 24px */
  }

  .behind__travel-head {
    display: flex;
    flex-direction: column;
    gap: 120px;
    flex-shrink: 0;
    width: 135px;
  }

  .behind__travel-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-md); /* 12px */
  }

  .behind__travel-label {
    color: var(--color-text-grey-muted);
    margin: 0;
  }

  .behind__travel-year {
    color: var(--color-text-black);
    margin: 0;
  }

  .behind__travel-tag {
    color: var(--color-text-grey-muted);
    background-color: var(--color-bg-light-grey);
    padding: var(--space-inset-sm) var(--space-inset-lg);
    border-radius: var(--radius-l); /* 12px */
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
  }

  .behind__travel-photos {
    position: relative;
    width: 432px;
    height: 232px;
    flex-shrink: 0;
  }

  /* Shared photo box. Specific transforms applied below.
     The white frame is already baked into the exported PNGs, so NO CSS border
     here (a CSS border would double the frame thickness). Rounded corners +
     overflow kept so the box-shadow follows the photo's rounded silhouette. */
  .behind__photo {
    position: absolute;
    border-radius: var(--radius-l); /* 12px */
    overflow: hidden;
  }

  .behind__photo :global(img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .behind__photo--river {
    width: 148px;
    height: 184px;
    /* Position matches Figma rotation-wrapper center (left=41, w=220 →
       center x=151; photo width 148 → left = 151-74 = 77). */
    left: 77px;
    top: 19px;
    transform: rotate(-30deg);
    /* Fan-out reveal (animations.md §7.1): 600ms transform from stacked-
       at-building-center → final tilted spot. Stagger handled per-card. */
    transition: transform var(--duration-fan-out-card, 600ms) var(--ease-out);
    will-change: transform;
    box-shadow:
      -6.667px 110px 30.833px 0 rgba(102, 102, 102, 0),
      -4.167px 70px 28.333px 0 rgba(102, 102, 102, 0.01),
      -2.5px 39.167px 23.333px 0 rgba(102, 102, 102, 0.05);
  }

  .behind__photo--fontan {
    width: 148px;
    height: 184px;
    /* Center x = 280 (wrapper left=170 + w=220/2); left = 280-74 = 206. */
    left: 206px;
    top: 19px;
    transform: rotate(30deg);
    /* Fan-out reveal (animations.md §7.1): same 600ms transform, staggered
       120ms after river so the two sides fan out one after the other. */
    transition: transform var(--duration-fan-out-card, 600ms) var(--ease-out) 120ms;
    will-change: transform;
    box-shadow:
      -8px 132px 37px 0 rgba(102, 102, 102, 0),
      -5px 84px 34px 0 rgba(102, 102, 102, 0.01),
      -3px 47px 28px 0 rgba(102, 102, 102, 0.05),
      -1px 21px 21px 0 rgba(102, 102, 102, 0.09);
  }

  .behind__photo--building {
    width: 202px;
    height: 233px;
    left: 115px;
    top: -1px;
    border-radius: 14px;
    box-shadow:
      -8px 132px 37px 0 rgba(102, 102, 102, 0),
      -5px 84px 34px 0 rgba(102, 102, 102, 0.01),
      -3px 47px 28px 0 rgba(102, 102, 102, 0.05);
  }

  /* ====== Latest books (col 2, row 2) ====== */
  .behind__card--books {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-lg); /* 16px */
  }

  .behind__books-title {
    color: var(--color-text-black);
    margin: 0;
  }

  .behind__books-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-sm); /* 8px */
  }

  .behind__book {
    display: flex;
    align-items: center;
    gap: var(--space-inline-sm); /* 8px */
  }

  .behind__book-check {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    display: block;
    border-radius: 5.5px;
  }

  .behind__book-title {
    color: var(--color-neutral-grey-200);
    /* Custom strikethrough (animatable). Native text-decoration: line-through
       can't be scaled in/out, so we draw a horizontal line via ::after on the
       title span and animate scaleX from 0 → 1, left-anchored. Per-book
       stagger lives on :nth-child(n) below. */
    position: relative;
    margin: 0;
  }

  .behind__book-title::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    /* 58% (not 50%) because the span's geometric center sits above the
       optical middle of the letterforms — line-height pads the bbox top
       with empty space, so a true 50% reads as "too high" through the text.
       58% lands the strike through the x-height middle (Marianna's note). */
    top: 58%;
    height: 1.5px;
    background: currentColor;
    transform-origin: left center;
    /* Default = revealed (no-JS fallback + post-animation state). JS sets
       data-strike-state="initial" on the <ul> to hide all lines, then
       removes it on viewport-enter so the transitions kick in. */
    transform: translateY(-50%) scaleX(1);
    transition: transform 700ms var(--ease-out);
    pointer-events: none;
  }

  /* Stagger: book #1 → 0ms, #2 → 500ms, #3 → 1000ms (slower-paced reveal
     per Marianna; was 0/300/600). */
  .behind__book:nth-child(2) .behind__book-title::after { transition-delay: 500ms; }
  .behind__book:nth-child(3) .behind__book-title::after { transition-delay: 1000ms; }

  /* Pre-animation state — lines hidden, no transition (so JS toggling the
     attribute doesn't make them animate OUT, only IN when removed). */
  .behind__books-list[data-strike-state="initial"] .behind__book-title::after {
    transform: translateY(-50%) scaleX(0);
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .behind__book-title::after {
      transition: none;
    }
  }

  /* ====== That's it (col 3, row 2) ====== */
  .behind__card--end {
    grid-column: 3;
    grid-row: 2;
    background-color: #F0F0EF;
    /* Native CSS dashed border can't reproduce the Figma 0.1×8 stroke
       pattern — use Border.svg overlay instead (vector-effect non-scaling
       so the dot density stays uniform at any card width). */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }

  /* Injected via set:html → scoped attrs aren't added to these nodes, so use
     :global. Desktop border shown by default; mobile border hidden until ≤767px. */
  :global(.behind__end-border) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    display: block;
    z-index: var(--z-base);
  }

  :global(.behind__end-border--mobile) {
    display: none;
  }

  .behind__end-heart {
    width: 52px;
    height: 52px;
    align-self: flex-start;
    display: block;
    position: relative;
    z-index: var(--z-elevated);
  }

  .behind__end-text {
    color: var(--color-text-grey-muted);
    text-align: right;
    margin: 0;
    align-self: stretch;
    position: relative;
    z-index: var(--z-elevated);
  }

  .behind__end-text strong {
    font-weight: var(--font-weight-semibold);
  }

  /* ====== Tablet + Mobile (≤1279px) — stacked layout ======
     The 3-col grid only works when viewport ≥ container-max-width (1280)
     — at narrower widths the About me column shrinks below the size
     needed to fit Body/mono/large bio text in 580px height. Below 1280
     we stack all four cards in a single column. */
  @media (max-width: 1279px) {
    .behind__grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-auto-rows: auto;
    }

    /* All cards reset to single column, auto-row */
    .behind__card--about,
    .behind__card--travel,
    .behind__card--books,
    .behind__card--end {
      grid-column: 1;
      grid-row: auto;
    }

    .behind__card {
      padding: var(--space-inset-xl); /* 16px on mobile */
    }

    /* About me — full width, auto height, smaller scallops (20px).
       Padding 0 here (mobile .behind__card rule above sets 16px, but
       About me uses inner .behind__paper for padding instead). */
    .behind__card--about {
      --scallop-diameter: 20px;
      --scallop-gap: 10px;
      --scallop-tile: calc(var(--scallop-diameter) + var(--scallop-gap));

      width: 100%;
      height: auto;
      min-height: 0;
      padding: 0;
    }

    /* Inner paper mobile padding per Marianna: 28 sides, 40 top, 32 bot. */
    .behind__paper {
      padding-inline: 28px;
      padding-block-start: 40px;
      padding-block-end: 32px;
    }

    /* Traveling card: stack header above photos */
    .behind__card--travel {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-stack-xl); /* 16px */
    }

    .behind__travel-head {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-inline-md);
      width: 100%;
    }

    .behind__travel-info {
      gap: var(--space-stack-xs); /* 4px */
    }

    .behind__travel-photos {
      /* Photos frame is fixed 432×232 (absolute children rely on those
         coords). Mobile card content is narrower than 432, so scale the
         whole frame down. Layout height collapsed to match visual height
         so no extra whitespace below. */
      align-self: center;
      transform: scale(0.68);
      transform-origin: top center;
      height: calc(232px * 0.68); /* ~158px laid-out height */
    }

    /* Books — heading 18px on mobile per spec (overrides H4 token 20px) */
    .behind__books-title {
      font-size: 18px;
    }

    /* That's it — heart + text on same horizontal line, smaller card */
    .behind__card--end {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-inline-md);
      padding: var(--space-inset-xl); /* 16px */
    }

    /* The card is now a short 64px-tall row. Swap to the flat-card border
       (drawn at 346×66, 16px corners) so the dots wrap the corners — the tall
       desktop border would leave the flat corners empty here. */
    :global(.behind__end-border--desktop) { display: none; }
    :global(.behind__end-border--mobile)  { display: block; }

    .behind__end-heart {
      width: 32px;
      height: 32px;
      flex-shrink: 0;
      align-self: center;
    }

    .behind__end-text {
      text-align: right;
      flex: 1 1 auto;
      align-self: center;
    }
  }

  /* ====== Travelling fan-out reveal — initial (stacked) state ======
     animations.md §7.1. JS adds data-fan-state="initial" before observing,
     which snaps river+fontan onto building's center with NO rotation and
     NO transition (so it doesn't animate INTO the stacked state). When
     the section scrolls into view, JS removes the attribute → the
     default .behind__photo--river/fontan transitions kick in and the
     cards fan out to their tilted positions (river first, fontan +120ms).

     Translate offsets = distance from each photo's center to building's
     center (frame 432×232, building center ≈ 216, 115.5):
       river  center 151,111  → dx +65,  dy +4.5
       fontan center 280,111  → dx -64,  dy +4.5 */
  .behind__travel-photos[data-fan-state="initial"] .behind__photo--river {
    transform: translate(65px, 4.5px) rotate(0deg);
    transition: none;
  }

  .behind__travel-photos[data-fan-state="initial"] .behind__photo--fontan {
    transform: translate(-64px, 4.5px) rotate(0deg);
    transition: none;
  }

  /* Reduced motion — final fanned state from the start; no animation.
     JS already short-circuits (doesn't set the initial attribute), but
     belt-and-braces: kill the transition so any forced toggle is instant. */
  @media (prefers-reduced-motion: reduce) {
    .behind__photo--river,
    .behind__photo--fontan {
      transition: none;
    }
  }
</style>

<script>
  /* Behind-the-Screen animations.
     1) Travelling fan-out reveal (animations.md §7.1) — river + fontan
        emerge from behind the building card when the photos enter view.
     2) Books strikethrough reveal — three list lines draw L→R with a
        stagger, but ONLY after the fan-out has settled (Marianna's note —
        otherwise both animations fight for attention). The wait is
        implemented via a shared Promise reset per page mount. */

  // Reset per page mount — otherwise on a second visit (Astro ClientRouter)
  // the previously-resolved promise would let the books strike fire
  // immediately, skipping the wait.
  let fanoutDoneResolve: (() => void) | undefined;
  let fanoutDone: Promise<void>;
  function resetFanoutPromise() {
    fanoutDone = new Promise<void>((r) => { fanoutDoneResolve = r; });
  }
  resetFanoutPromise();

  // Fan-out timing matches the CSS: river at delay 0 + 600ms, fontan at
  // delay 120ms + 600ms. The last card finishes at 720ms after IO fires.
  const FANOUT_TOTAL_MS = 720;

  function initTravelFanOut() {
    const photos = document.querySelector<HTMLElement>('[data-fan-photos]');
    if (!photos || photos.dataset.fanInit === '1') return;
    photos.dataset.fanInit = '1';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      fanoutDoneResolve?.();
      return;
    }

    photos.setAttribute('data-fan-state', 'initial');

    const io = new IntersectionObserver((entries, obs) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          requestAnimationFrame(() => {
            photos.removeAttribute('data-fan-state');
            setTimeout(() => fanoutDoneResolve?.(), FANOUT_TOTAL_MS);
          });
          obs.unobserve(entry.target);
        }
      }
    }, { threshold: 0.4 });

    io.observe(photos);
  }

  function initBooksStrike() {
    const list = document.querySelector<HTMLElement>('[data-strike-list]');
    if (!list || list.dataset.strikeInit === '1') return;
    list.dataset.strikeInit = '1';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    list.setAttribute('data-strike-state', 'initial');

    const io = new IntersectionObserver((entries, obs) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          // Wait until the fan-out reveal has settled before drawing the
          // strikethrough lines (so the eye doesn't track both at once).
          fanoutDone.then(() => {
            requestAnimationFrame(() => list.removeAttribute('data-strike-state'));
          });
          obs.unobserve(entry.target);
        }
      }
    }, { threshold: 0.4 });

    io.observe(list);
  }

  function initBehindAnimations() {
    resetFanoutPromise();
    initTravelFanOut();
    initBooksStrike();
  }

  // Initial page load.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBehindAnimations);
  } else {
    initBehindAnimations();
  }
  // Astro View Transitions: re-init on each client-side navigation.
  document.addEventListener('astro:page-load', initBehindAnimations);
</script>
