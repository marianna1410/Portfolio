---
/**
 * Footer.astro — global site footer. Two variants:
 *   'default' (home pages) — outer light-grey background, inner WHITE card.
 *   'case'    (case study pages, Figma 472:17361) — colors INVERTED:
 *                outer WHITE background, inner LIGHT-GREY card.
 * Everything else (typography, links, illustration) is identical.
 */
import ArrowSwap from './ArrowSwap.astro';
import diagonalArrow from '../assets/icons/diagonal-arrow-dark-grey.svg';
import birdRaw from '../assets/icons/footer-bird.svg?raw';
import { CONTACT, RESUME_URL } from '../lib/config.ts';

interface Props {
  variant?: 'default' | 'case';
}

const { variant = 'default' } = Astro.props;

/**
 * Dotted line + bird "highlight wave" (animations.md §11.1).
 * The line is rebuilt as discrete dots (the source SVG is one dashed path),
 * the bird already ships as 99 individual <circle>s. Every dot gets an
 * animation-delay proportional to its left-to-right position, so a soft
 * darkening wave (grey → text/black) travels along the line and into the
 * bird, looping. Pure CSS — see .footer__dot below.
 */
// Wave timing — line and bird sweep at DIFFERENT paces (decoupled):
const LINE_DURATION = 4.5; // s — wave crossing the dotted line (the brisk "as-before" pace)
const BIRD_DURATION = 0.9; // s — wave crossing the bird (kept slow on purpose)
const WAVE_CYCLE = LINE_DURATION + BIRD_DURATION; // total loop; pushed to CSS via --wave-cycle

// Line dots: evenly spaced along the 273px line (viewBox 0 0 275 2).
const lineDots: { cx: number; absX: number; delay: number }[] = [];
for (let x = 1; x <= 273; x += 8) lineDots.push({ cx: x, absX: x, delay: 0 });

// Bird dots: parsed from the source SVG; absolute x offset by the bird's
// left position (278px) so it orders after the line.
const birdDots = [...birdRaw.matchAll(/cx="([\d.]+)"\s+cy="([\d.]+)"/g)].map((m) => ({
  cx: Number(m[1]),
  cy: Number(m[2]),
  absX: 278 + Number(m[1]),
  delay: 0,
}));

// Delay is keyed to each dot's HORIZONTAL position (not its index) and
// quantized into vertical columns, so dots sharing an x-band light up together
// — the wave sweeps left → right covering several rows at once (rather than
// crawling dot-by-dot, which read as a diagonal bottom-up climb in the bird).
// The line and the bird run at their own even paces, joined at the seam.
const WAVE_BIN = 2; // px — width of one wavefront column

// delay = (when the band reaches this dot) − cycle → negative, seamless, L→R.
const assignWave = (dots: { absX: number; delay: number }[], tStart: number, duration: number) => {
  const xs = dots.map((d) => d.absX);
  const min = Math.min(...xs);
  const span = (Math.max(...xs) - min) || 1;
  dots.forEach((d) => {
    const colX = Math.round(d.absX / WAVE_BIN) * WAVE_BIN; // snap to column
    const u = (colX - min) / span;                          // 0 … 1 within this segment
    d.delay = tStart + u * duration - WAVE_CYCLE;
  });
};
assignWave(lineDots, 0, LINE_DURATION);
assignWave(birdDots, LINE_DURATION, BIRD_DURATION);
---

<footer class:list={['footer', `footer--${variant}`]} aria-label="Site footer">
  <div class="footer__card">
    <div class="footer__row">

      <div class="footer__cta-title">
        <p class="text-h4-medium">Ready to start building?</p>
      </div>

      <div class="footer__illustration" aria-hidden="true" style={`--wave-cycle:${WAVE_CYCLE}s`}>
        <svg
          class="footer__illustration-line"
          viewBox="0 0 275 2"
          preserveAspectRatio="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          {lineDots.map((d) => (
            <circle class="footer__dot" cx={d.cx} cy="1" r="1" style={`animation-delay:${d.delay}s`} />
          ))}
        </svg>
        <svg
          class="footer__illustration-bird"
          viewBox="0 0 27.1529 34.3031"
          preserveAspectRatio="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          {birdDots.map((d) => (
            <circle class="footer__dot" cx={d.cx} cy={d.cy} r="0.75" style={`animation-delay:${d.delay}s`} />
          ))}
        </svg>
      </div>

      <div class="footer__links-group">
        <p class="footer__links-heading text-headline-medium">Let&#8217;s get in touch</p>
        <ul class="footer__links">
          <li>
            <a
              href={`mailto:${CONTACT.email}`}
              class="footer__link text-label"
              aria-label={`Email Marianna at ${CONTACT.email} (opens mail client)`}
            >
              <span>Email</span>
              <ArrowSwap icon={diagonalArrow} class="footer__link-arrow" />
            </a>
          </li>
          <li>
            <a
              href={CONTACT.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__link text-label"
            >
              <span>LinkedIn</span>
              <ArrowSwap icon={diagonalArrow} class="footer__link-arrow" />
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
          <li>
            <a
              href={CONTACT.telegram}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__link text-label"
            >
              <span>Telegram</span>
              <ArrowSwap icon={diagonalArrow} class="footer__link-arrow" />
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
          <li>
            <a
              href={RESUME_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__link text-label"
            >
              <span>Resume</span>
              <ArrowSwap icon={diagonalArrow} class="footer__link-arrow" />
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
        </ul>
      </div>

    </div>
  </div>
</footer>

<style>
  /* ====== Outer footer shell ====== */
  .footer {
    padding-top: var(--space-stack-md);       /* 12px — matches Figma pt */
    padding-bottom: var(--space-stack-3xl);   /* 32px — matches Figma pb */
    padding-inline: var(--container-padding-mobile); /* 20px mobile */
  }

  /* Color variants (only the bgs swap between outer + card). */
  .footer--default { background-color: var(--color-bg-light-grey); }
  .footer--case    { background-color: var(--color-bg-white); }

  @media (min-width: 768px) {
    .footer {
      padding-inline: var(--container-padding-tablet); /* 32px */
    }
  }

  @media (min-width: 1280px) {
    .footer {
      padding-inline: var(--container-padding-desktop); /* 64px */
    }
  }

  /* ====== Inner card ====== */
  .footer__card {
    border-radius: var(--radius-2xl);
    padding: var(--space-inline-3xl); /* 32px all sides */
  }

  /* Inner card color is the inverse of the outer shell. */
  .footer--default .footer__card { background-color: var(--color-bg-white); }
  .footer--case    .footer__card { background-color: var(--color-bg-light-grey); }

  /* Desktop: fix card height to 178px, content top-aligned */
  @media (min-width: 768px) {
    .footer__card {
      height: 178px;
    }
  }

  /* ====== Inner flex row ====== */
  .footer__row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-inline-2xl); /* 24px */
  }

  /* Stack vertically on mobile */
  @media (max-width: 767px) {
    .footer__row {
      flex-direction: column;
      gap: var(--space-stack-3xl); /* 32px */
    }
  }

  /* ====== CTA title ====== */
  .footer__cta-title {
    display: flex;
    align-items: center;
    padding-top: var(--space-inset-sm); /* 8px — aligns baseline with illustration */
    flex-shrink: 0;
  }

  .footer__cta-title p {
    color: var(--color-text-black);
    white-space: nowrap;
    /* font-size uses --font-size-h4 via .text-h4-medium:
       desktop 24px → mobile 20px handled globally in tokens.css */
  }

  /* ====== Dotted-line + bird illustration ====== */
  .footer__illustration {
    position: relative;
    width: 309px;
    height: 40px;
    flex-shrink: 0;
  }

  /* Hidden on mobile + narrow tablet — decorative only. The 309px fixed
     width crowds the row below ~1024px, pushing the 4 link arrows past
     the viewport edge. Reappears at >=1024px where there's room. */
  @media (max-width: 1023px) {
    .footer__illustration {
      display: none;
    }
  }

  .footer__illustration-line {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 273px;
    height: 2px;
    display: block;
  }

  .footer__illustration-bird {
    position: absolute;
    left: 278px;
    top: 3px;
    width: 27px;
    height: 34px;
    display: block;
  }

  /* ── Dot highlight wave (animations.md §11.1) ──
     Every dot (line + bird) darkens grey → text/black → grey. Each dot's
     animation-delay is set inline (frontmatter) from its left-to-right
     position, so the bright band sweeps along the line and into the bird,
     looping seamlessly. */
  .footer__dot {
    fill: var(--color-stroke-medium-grey); /* #BBBBBB base */
    animation: footer-dot-wave var(--wave-cycle, 5.4s) ease-in-out infinite; /* duration fed from frontmatter */
  }

  @keyframes footer-dot-wave {
    0%   { fill: var(--color-stroke-medium-grey); }
    6%   { fill: var(--color-text-black); }   /* #252525 peak */
    12%  { fill: var(--color-stroke-medium-grey); }
    100% { fill: var(--color-stroke-medium-grey); }
  }

  /* Reduced motion: no wave — dots stay at the base grey. */
  @media (prefers-reduced-motion: reduce) {
    .footer__dot {
      animation: none;
      fill: var(--color-stroke-medium-grey);
    }
  }

  /* ====== Links group (right column) ====== */
  .footer__links-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-lg); /* 16px */
    padding-top: var(--space-inset-sm); /* 8px */
    flex: 1;
    min-width: 0;
  }

  .footer__links-heading {
    color: var(--color-text-grey-muted);
  }

  /* Mobile: 20px → 16px (explicit design decision).
     Uses --font-size-body-large which is 16px on mobile. */
  @media (max-width: 767px) {
    .footer__links-heading {
      font-size: var(--font-size-body-large); /* mobile value: 16px */
    }
  }

  .footer__links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-inline-lg); /* 16px desktop / 12px mobile between links */
    list-style: none;
  }

  /* Mobile: reduce the gap between links — both horizontal and the
     vertical gap between wrapped rows — from 12px to 8px. */
  @media (max-width: 767px) {
    .footer__links {
      gap: var(--space-inline-sm); /* 8px (both axes) */
    }
  }

  /* ====== Individual link ====== */
  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-inset-sm); /* 8px between text and icon */
    height: 32px;
    padding: var(--space-inset-xs) 2px var(--space-inset-xs) var(--space-inset-xs);
    border-radius: var(--radius-l);
    color: var(--color-text-dark-grey);
  }

  .footer__link-arrow {
    display: block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Minimum 44×44 tap target on touch devices */
  @media (pointer: coarse) {
    .footer__link {
      min-height: 44px;
    }
  }
</style>
