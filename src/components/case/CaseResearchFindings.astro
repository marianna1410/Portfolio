---
/**
 * CaseResearchFindings.astro — second sub-block of the Research section.
 * Figma 472:17164 "Mentioned problems".
 *
 *   Heading (h5 20 SemiBold #252525)
 *   ↕ 12px stack
 *   Ordered list (5 items, 18 Regular #737373, list-decimal, 8px between)
 *   ↕ 20px outer stack
 *   User's feedback composite image (868×536, bg #F4F4F3, rounded 12)
 *   ↕ 16px stack
 *   Caption (18 Regular #737373)
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  heading: string;
  items: string[];      // ordered list items
  image: ImageMetadata; // User's feedback composite
  imageAlt: string;
  caption: string;
}

const { heading, items, image, imageAlt, caption } = Astro.props;
---

<div class="research-findings">
  <div class="research-findings__text">
    <p class="research-findings__heading text-headline-semibold">{heading}</p>
    <ol class="research-findings__list">
      {items.map((item) => (
        <li class="research-findings__list-item">{item}</li>
      ))}
    </ol>
  </div>

  <div class="research-findings__media">
    <div class="research-findings__image-wrap">
      <Image
        src={image}
        alt={imageAlt}
        width={1736}
        height={1072}
        quality={90}
        class="research-findings__image"
      />
    </div>
    <p class="research-findings__caption">{caption}</p>
  </div>
</div>

<style>
  .research-findings {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-xl); /* 20px between text block and media block */
    width: 100%;
  }

  /* ── Text block ──────────────────────────────────────────────────────── */
  .research-findings__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-md); /* 12px */
  }

  .research-findings__heading {
    /* .text-headline-semibold = 20 SemiBold 1.1 2% */
    margin: 0;
    color: var(--color-text-black);
  }

  .research-findings__list {
    margin: 0;
    padding-left: 27px; /* matches Figma ms-[27px] */
    list-style: decimal;
    color: var(--color-text-grey-muted);
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-body-large); /* 18 */
    line-height: var(--line-height-base);   /* 1.48 */
    letter-spacing: var(--letter-spacing-wide);
  }

  .research-findings__list-item + .research-findings__list-item {
    margin-top: var(--space-stack-sm); /* 8px between items (Figma mb-[8px]) */
  }

  /* ── Media block ─────────────────────────────────────────────────────── */
  .research-findings__media {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-lg); /* 16px between image and caption */
  }

  .research-findings__image-wrap {
    width: 100%;
    aspect-ratio: 868 / 536;
    background-color: var(--color-bg-light-grey); /* #F4F4F3 — backdrop per Figma */
    border-radius: var(--radius-l); /* 12px */
    overflow: hidden;
  }

  .research-findings__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .research-findings__caption {
    margin: 0;
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-body-large);
    line-height: var(--line-height-base);
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-grey-muted);
  }
</style>
