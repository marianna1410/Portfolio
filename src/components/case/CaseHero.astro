---
/**
 * CaseHero.astro — title block + hero image at top of case study.
 * Figma node 472:17113 (Lucida hero) / 472:20856 (Vaia hero) — same structure.
 *
 * Tag rail: first chip is the case number ("01", "02"), then two text tags.
 * Title: h2 (Figma uses 40px Inter Tight Medium for case-page hero, NOT 48px h1).
 * Image: 868×562, radius 20px.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  /** "01", "02" — first chip on the tag rail */
  number: string;
  /** Remaining tag labels rendered after the number chip */
  tags: string[];
  /** Hero title (rendered as <h1> for SEO/a11y, styled like h2) */
  title: string;
  /** Hero image — imported via `import heroImg from '...'` */
  image: ImageMetadata;
  /** Alt text for the hero image */
  imageAlt: string;
}

const { number, tags, title, image, imageAlt } = Astro.props;
---

<header class="case-hero" id="top">
  <div class="case-hero__title-block">
    <div class="case-hero__tag-rail" aria-label="Case study tags">
      <span class="case-hero__tag case-hero__tag--number">{number}</span>
      {tags.map((tag) => (
        <span class="case-hero__tag">{tag}</span>
      ))}
    </div>
    <h1 class="case-hero__title text-h2">{title}</h1>
  </div>
  <div class="case-hero__image-wrap">
    <Image
      src={image}
      alt={imageAlt}
      width={1736}
      height={1124}
      quality={90}
      class="case-hero__image"
      loading="eager"
    />
  </div>
</header>

<style>
  .case-hero {
    display: flex;
    flex-direction: column;
    gap: 48px; /* Figma: gap between title block and image */
    margin: 0;
  }

  .case-hero__title-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-2xl); /* 24px */
  }

  .case-hero__tag-rail {
    display: flex;
    align-items: center;
    gap: var(--space-inline-sm); /* 8px */
    flex-wrap: wrap;
  }

  .case-hero__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 36px; /* Figma height for tag chip */
    padding: var(--space-inset-sm) var(--space-inset-lg); /* 8 × 16 */
    border-radius: var(--radius-l); /* 12px */
    background-color: var(--color-bg-light-grey);
    color: var(--color-text-grey-muted);
    font-family: var(--font-family-mono);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-caption-mono);
    line-height: var(--line-height-loose);
    letter-spacing: var(--letter-spacing-normal);
    white-space: nowrap;
  }

  .case-hero__tag--number {
    /* "01" chip: Figma sets fixed width 40, centered text */
    width: 40px;
    padding-inline: 0;
  }

  .case-hero__title {
    /* .text-h2 utility from tokens.css does the typography.
       Color override unnecessary — black is the default. */
    margin: 0;
    color: var(--color-text-black);
  }

  .case-hero__image-wrap {
    width: 100%;
    border-radius: var(--radius-2xl); /* 20px */
    overflow: hidden;
    /* Maintain Figma aspect ratio 868:562 so layout doesn't shift */
    aspect-ratio: 868 / 562;
  }

  .case-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Mobile (placeholder fallback only — no Figma mobile design yet) */
  @media (max-width: 767px) {
    .case-hero {
      gap: var(--space-stack-3xl);
    }

    .case-hero__title-block {
      gap: var(--space-stack-lg);
    }

    .case-hero__image-wrap {
      border-radius: var(--radius-xl);
    }
  }
</style>
