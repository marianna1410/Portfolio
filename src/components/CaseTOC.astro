---
/**
 * CaseTOC.astro — table-of-contents sidebar for case study pages.
 *
 * Two visual modes, controlled purely by viewport width:
 *
 *   ≥1280px (desktop):  sticky inline TOC in the left sidebar grid column,
 *                       no FAB — current original behaviour.
 *
 *   ≤1279px (tablet + mobile):  small FAB pinned to bottom-right of the
 *                       viewport (24 px from edges on mobile, 40 px on
 *                       tablet — Marianna's spec). Clicking the FAB opens
 *                       a 200 px-wide popup TOC to the LEFT of the FAB,
 *                       bottom-aligned with it, 16 px gap. Per Figma
 *                       769:20694 (FAB component) + 768:18976 (Mobile_TOC
 *                       layout).
 *
 * Trigger: click on FAB toggles the popup.
 * Close:   click FAB again / click outside / Esc / click any link.
 *
 * Both modes share ONE DOM tree, so the scroll-spy script picks up the
 * active section once and the highlighted state is reflected in either
 * visible mode.
 */
import { Image } from 'astro:assets';
import triangleRight from '../assets/icons/triangle-right.svg';
import triangleRightGrey from '../assets/icons/triangle-right-grey.svg';
import iconTocContent from '../assets/icons/icon-toc-content.svg';
import iconTocClose from '../assets/icons/icon-toc-close.svg';

interface Item {
  id: string;
  label: string;
}

interface Props {
  items?: Item[];
  /** id of the currently-active section (matches an item.id) */
  active?: string;
}

const {
  items = [
    { id: 'overview',  label: 'Project Overview' },
    { id: 'research',  label: 'Research' },
    { id: 'problems',  label: 'Problems' },
    { id: 'solutions', label: 'Solutions' },
    { id: 'summary',   label: 'Summary' },
  ],
  active = 'overview',
} = Astro.props;
---

<div class="case-toc-wrapper" data-toc-wrapper>
  {/* FAB — visible only at ≤1279px. */}
  <button
    type="button"
    class="case-toc__fab"
    aria-expanded="false"
    aria-controls="case-toc-list"
    aria-label="Open table of contents"
    data-toc-fab
  >
    <span class="case-toc__fab-icons" aria-hidden="true">
      <Image src={iconTocContent} alt="" width={20} height={20} class="case-toc__fab-icon case-toc__fab-icon--closed" />
      <Image src={iconTocClose}   alt="" width={20} height={20} class="case-toc__fab-icon case-toc__fab-icon--open" />
    </span>
  </button>

  <nav class="case-toc" id="case-toc-list" aria-label="Case study sections">
    {/* Title + dotted divider — visible only in popup mode (≤1279px). */}
    <p class="case-toc__title">Table of Contents</p>
    <svg
      class="case-toc__divider"
      viewBox="0 0 178 2"
      preserveAspectRatio="none"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M1 1H177" stroke="#BBBBBB" stroke-width="2" stroke-linecap="round" stroke-dasharray="0.1 8" vector-effect="non-scaling-stroke" />
    </svg>

    <ul class="case-toc__list">
      {items.map((item) => {
        const isActive = item.id === active;
        return (
          <li class="case-toc__item">
            <a
              href={`#${item.id}`}
              class:list={['case-toc__link', { 'case-toc__link--active': isActive }]}
              aria-current={isActive ? 'true' : undefined}
              data-toc-link
              data-target={item.id}
            >
              <span class="case-toc__icon" aria-hidden="true">
                {/* Two pre-rendered triangle variants stacked in the 20×20 slot.
                    CSS shows the black one for the current link, the grey one on hover. */}
                <Image src={triangleRight}      alt="" width={20} height={20} class="case-toc__icon-img case-toc__icon-img--active" />
                <Image src={triangleRightGrey}  alt="" width={20} height={20} class="case-toc__icon-img case-toc__icon-img--hover" />
              </span>
              <span class="case-toc__label">{item.label}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</div>

<style>
  /* ═══ Shared base (used by both modes; per-mode overrides further down) ═══ */
  .case-toc-wrapper {
    /* Default = desktop. The wrapper acts as the sticky sidebar column. */
    width: 193px;
    position: sticky;
    top: 24px;
    align-self: start;

    /* Multi-layer drop shadow from Figma "Small elements" effect — used on
       BOTH the FAB and the popup TOC in popup mode so they read as one
       lifted-from-page system. Declared once here, consumed twice below. */
    --shadow-fab:
      0  1px 1px 0 rgba(186, 186, 186, 0.10),
      0  3px 3px 0 rgba(186, 186, 186, 0.09),
      0  6px 4px 0 rgba(186, 186, 186, 0.05),
      0 11px 4px 0 rgba(186, 186, 186, 0.01),
      0 17px 5px 0 rgba(186, 186, 186, 0.00);
  }

  .case-toc {
    /* Desktop inline TOC layout — original spec. */
    width: 193px;
    padding: 0 var(--space-inset-md) var(--space-inset-md);
    display: flex;
    flex-direction: column;
  }

  /* Title + divider exist in DOM at all widths so the SAME node tree works in
     both modes; they're only revealed in popup mode via media queries below. */
  .case-toc__title,
  .case-toc__divider {
    display: none;
  }

  .case-toc__list {
    display: flex;
    flex-direction: column;
    gap: 11px; /* exact desktop value from Figma */
    list-style: none;
    margin: 0;
    padding: 0;
    width: 169px; /* inner "Con" frame width on desktop */
  }

  .case-toc__item { margin: 0; }

  .case-toc__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-inset-xs);
    padding: var(--space-inset-xs);
    border-radius: var(--radius-l);
    color: var(--color-text-grey-muted);
    text-decoration: none;
    font-family: var(--font-family-body);
    font-weight: var(--font-weight-regular);
    font-size: var(--font-size-body-large);
    line-height: var(--line-height-base);
    letter-spacing: var(--letter-spacing-wide);
    white-space: nowrap;
    transition: color var(--duration-base) var(--ease-out); /* 200ms (animations.md §8.2) */
  }

  .case-toc__link--active { color: var(--color-text-black); }

  .case-toc__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    position: relative;
  }
  /* Two triangles stacked in the slot; cross-fade via opacity (not display)
     so the active-state change animates smoothly. 200ms ease-out. */
  .case-toc__icon-img {
    position: absolute;
    inset: 0;
    display: block;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }
  /* Active section (scroll-spy driven): black triangle fades in. */
  .case-toc__link--active .case-toc__icon-img--active { opacity: 1; }
  /* Hover on a non-active link: grey triangle — pointer devices only. */
  @media (hover: hover) and (pointer: fine) {
    .case-toc__link:hover:not(.case-toc__link--active) .case-toc__icon-img--hover { opacity: 1; }
  }

  /* Focus uses the global :focus-visible from global.css
     (2px solid var(--color-bg-black) outline, 2px offset, per a11y.md §3.1).
     Dropped the local --shadow-focus override — that ring was 4px black
     halo + 2px white inner, visually heavy and out of sync with the rest
     of the site. Same fix as Header (commit 92c463b). */

  /* FAB — hidden on desktop. */
  .case-toc__fab { display: none; }

  /* ═══ Popup mode (≤1279px): FAB pinned to bottom-right, TOC popup
         opens to its left, both bottom-aligned. ═══ */
  @media (max-width: 1279px) {
    /* Wrapper becomes a pass-through so its children stay free of grid flow.
       Both .case-toc__fab and .case-toc are position:fixed below, so neither
       takes up any space in normal flow. */
    .case-toc-wrapper {
      position: static;
      width: auto;
      top: auto;
      align-self: auto;
    }

    .case-toc__fab {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      padding: var(--space-inset-md); /* 12px */
      background-color: var(--color-bg-light-grey);
      border: 1px solid transparent;
      border-radius: var(--radius-pill);
      cursor: pointer;
      box-shadow: var(--shadow-fab);
      /* Pinned to bottom-right of viewport. Mobile values; tablet override
         below bumps these to 40px. */
      position: fixed;
      bottom: 24px;
      right: 24px;
      z-index: 50;
    }

    /* Focus uses the global :focus-visible (2px solid #252525 outline). */

    .case-toc__fab-icons {
      position: relative;
      width: 20px;
      height: 20px;
      display: inline-block;
    }
    .case-toc__fab-icon {
      position: absolute;
      inset: 0;
      display: block;
    }
    /* By default show the content (list) icon; hide the close icon. */
    .case-toc__fab-icon--open { display: none; }
    /* When open, swap the icons. */
    .case-toc-wrapper.is-open .case-toc__fab-icon--closed { display: none; }
    .case-toc-wrapper.is-open .case-toc__fab-icon--open   { display: block; }

    /* TOC popup container — 200 px wide per Figma, anchored to FAB. */
    .case-toc {
      position: fixed;
      bottom: 24px; /* same as FAB */
      /* Sit 16 px to the LEFT of the FAB: FAB right (24) + FAB width (44) + gap (16) = 84 */
      right: calc(24px + 44px + 16px);
      width: 200px;
      max-height: calc(100vh - 48px - 80px); /* keep inside viewport, leave room above header */
      overflow-y: auto;
      padding: var(--space-inset-sm) var(--space-inset-md); /* 8px 12px */
      background-color: var(--color-bg-light-grey);
      border-radius: var(--radius-l); /* 12px */
      box-shadow: var(--shadow-fab);
      gap: var(--space-stack-sm); /* 8px */
      z-index: 50;
      /* Hidden until .is-open is applied. */
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
    }

    .case-toc-wrapper.is-open .case-toc {
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
    }

    /* Title row: "Table of Contents" — mono caption.
       Padding matches Figma 768:20633 → I768:20633;768:17188: padding-left
       12 (indents text to 24 px from container outer edge alongside the
       container's own 12 px inset) and py-4 (4 top + 4 bottom). The 4 px
       padding-bottom stacks on top of the parent's 8 px flex gap to
       produce the 12 px visible distance between title and divider per
       Marianna's spec. Line-height uses --line-height-loose (1.4), Figma's
       Fira Code caption-mono leading. padding-left is a literal 12 px
       because --space-inset-md crosses 8/12 between mobile and tablet
       while we need a constant 12 px across the whole popup range. */
    .case-toc__title {
      display: block;
      margin: 0;
      padding: var(--space-inset-xs) 0 var(--space-inset-xs) 12px;
      font-family: var(--font-family-mono);
      font-weight: var(--font-weight-regular);
      font-size: var(--font-size-caption-mono);
      line-height: var(--line-height-loose);
      letter-spacing: var(--letter-spacing-wide);
      color: var(--color-text-grey-muted);
    }

    .case-toc__divider {
      display: block;
      width: 100%;
      height: 2px;
      flex-shrink: 0;
    }

    /* List adjustments for popup mode. */
    .case-toc__list {
      gap: var(--space-inset-xs); /* 4px between rows */
      width: 100%;
    }
    .case-toc__link {
      width: 100%;
      font-size: var(--font-size-body-medium); /* 16px popup */
    }
  }

  /* Tablet override — bigger viewport, larger inset (40 px from edges). */
  @media (min-width: 768px) and (max-width: 1279px) {
    .case-toc__fab {
      bottom: 40px;
      right: 40px;
    }
    .case-toc {
      bottom: 40px;
      right: calc(40px + 44px + 16px);
    }
  }
</style>

<script>
  /**
   * Two responsibilities:
   *   1. Scroll-spy: highlight the link whose section currently dominates
   *      the viewport (carried over from the original component).
   *   2. FAB popup behaviour at ≤1279px: open on FAB-click, close on
   *      FAB-click / outside-click / Esc / link-click. Selecting a link
   *      navigates to its anchor — the close happens BEFORE the scroll.
   *
   * Lifecycle: Astro View Transitions (<ClientRouter />) swaps the page
   * DOM without a full reload. DOMContentLoaded only fires on the very
   * first paint, so we ALSO listen on `astro:page-load` (which fires on
   * every navigation, including the first paint). To avoid leaking
   * document-level listeners across navigations, each init wraps all
   * handlers in an AbortController and aborts the previous one.
   */
  let currentAbort: AbortController | null = null;
  let currentObserver: IntersectionObserver | null = null;

  function initTocScrollSpy(signal: AbortSignal) {
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
    if (tocLinks.length === 0) return;

    const targetIds: string[] = [];
    tocLinks.forEach((link) => {
      const target = link.dataset.target;
      if (target) targetIds.push(target);
    });

    const sections = targetIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);
    if (sections.length === 0) return;

    const setActive = (id: string) => {
      tocLinks.forEach((link) => {
        const isActive = link.dataset.target === id;
        link.classList.toggle('case-toc__link--active', isActive);
        if (isActive) link.setAttribute('aria-current', 'true');
        else link.removeAttribute('aria-current');
      });
    };

    const visible = new Map<string, number>();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) visible.set(entry.target.id, entry.intersectionRatio);
          else visible.delete(entry.target.id);
        });

        if (visible.size === 0) {
          const activeLine = 180;
          let lastAbove: HTMLElement | null = null;
          sections.forEach((s) => {
            if (s.getBoundingClientRect().top <= activeLine) lastAbove = s;
          });
          if (lastAbove) setActive((lastAbove as HTMLElement).id);
          return;
        }

        let chosen: HTMLElement | null = null;
        let chosenTop = -Infinity;
        sections.forEach((s) => {
          if (visible.has(s.id)) {
            const top = s.getBoundingClientRect().top;
            if (top <= 180 && top > chosenTop) {
              chosen = s;
              chosenTop = top;
            }
          }
        });
        if (!chosen) {
          for (const s of sections) {
            if (visible.has(s.id)) { chosen = s; break; }
          }
        }
        if (chosen) setActive((chosen as HTMLElement).id);
      },
      {
        rootMargin: '-120px 0px -40% 0px',
        threshold: [0, 0.1, 0.5, 1],
      }
    );

    sections.forEach((s) => observer.observe(s));
    currentObserver = observer;

    // Disconnect when the controller fires abort (i.e. next page load).
    signal.addEventListener('abort', () => observer.disconnect());
  }

  function initTocFab(signal: AbortSignal) {
    const wrapper = document.querySelector<HTMLElement>('[data-toc-wrapper]');
    const fab = document.querySelector<HTMLButtonElement>('[data-toc-fab]');
    if (!wrapper || !fab) return;

    const close = () => {
      wrapper.classList.remove('is-open');
      fab.setAttribute('aria-expanded', 'false');
      fab.setAttribute('aria-label', 'Open table of contents');
    };
    const open = () => {
      wrapper.classList.add('is-open');
      fab.setAttribute('aria-expanded', 'true');
      fab.setAttribute('aria-label', 'Close table of contents');
    };
    const toggle = () => {
      if (wrapper.classList.contains('is-open')) close();
      else open();
    };

    fab.addEventListener('click', (e) => {
      e.stopPropagation();
      toggle();
    }, { signal });

    // Outside-click closes the popup. Clicks on the FAB itself are stopped
    // above so they don't double-toggle here.
    document.addEventListener('click', (e) => {
      if (!wrapper.classList.contains('is-open')) return;
      const target = e.target as Node;
      // If the click is inside the popup nav, don't close (let link handler do it).
      const nav = wrapper.querySelector('.case-toc');
      if (nav && nav.contains(target)) return;
      close();
    }, { signal });

    // Esc closes.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && wrapper.classList.contains('is-open')) {
        close();
        fab.focus();
      }
    }, { signal });

    // Click on any link inside the TOC closes the popup, then native anchor
    // navigation runs.
    wrapper.querySelectorAll<HTMLAnchorElement>('[data-toc-link]').forEach((link) => {
      link.addEventListener('click', () => close(), { signal });
    });

    // If user crosses the breakpoint back to desktop, force-close to avoid
    // leaving stale state lying around.
    const mq = window.matchMedia('(min-width: 1280px)');
    const handleBp = () => { if (mq.matches) close(); };
    if (mq.addEventListener) mq.addEventListener('change', handleBp, { signal });
    else mq.addListener(handleBp); // Safari < 14 fallback (no AbortController support)
  }

  function init() {
    // Abort any listeners + observer from the previous page so they don't
    // pile up across View Transitions navigations.
    currentAbort?.abort();
    currentObserver?.disconnect();
    currentAbort = new AbortController();
    initTocScrollSpy(currentAbort.signal);
    initTocFab(currentAbort.signal);
  }

  // First paint (no view transitions yet, or hard refresh on a case page).
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  // Astro View Transitions: fires on every page swap, including the first
  // paint when ClientRouter is mounted. The AbortController guard above
  // makes the double-call on first paint safe.
  document.addEventListener('astro:page-load', init);
</script>
